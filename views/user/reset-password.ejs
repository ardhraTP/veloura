<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }


        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .reset-container {
            background: var(--white);
            border-radius: 20px;
            padding: 60px 80px;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
        }

        .reset-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            font-weight: 400;
            color: var(--primary-red);
            margin-bottom: 15px;
            text-align: center;
        }

        .reset-subtitle {
            font-size: 14px;
            color: var(--text-light);
            margin-bottom: 40px;
            line-height: 1.6;
            text-align: center;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: var(--primary-red);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper {
            position: relative;
        }

        .form-group input {
            width: 100%;
            padding: 12px 45px 12px 15px;
            border: none;
            border-bottom: 1px solid var(--border-color);
            background-color: transparent;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s ease;
            color: var(--text-dark);
        }

        .form-group input:focus {
            outline: none;
            border-bottom-color: var(--primary-red);
        }

        .form-group input::placeholder {
            color: #d4b5bb;
            font-size: 13px;
        }

        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--primary-red);
            font-size: 18px;
            user-select: none;
        }

        .update-btn {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 30px;
        }

        .update-btn:hover {
            background-color: #552330;
        }

        .update-btn:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
        }

        .success-message {
            background-color: #efe;
            color: #2a7c2a;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #2a7c2a;
        }

        .field-error {
            color: #c33;
            font-size: 12px;
            margin-top: 5px;
            display: none;
        }

        .field-error.show {
            display: block;
        }

        @media (max-width: 768px) {
            .reset-container {
                padding: 40px 30px;
            }

            .reset-title {
                font-size: 32px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <div class="reset-container">
        <h1 class="reset-title">Reset Password</h1>
        <p class="reset-subtitle">
            Please enter your new password to secure your account.
        </p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message">
                <%= error %>
                <% if (error.includes('Invalid reset link') || error.includes('expired')) { %>
                    <br><br>
                    <a href="/forgot-password" style="color: var(--primary-red); text-decoration: underline;">Request a new reset link</a>
                <% } %>
            </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-message"><%= success %></div>
        <% } %>

        <% if (typeof token === 'undefined' || !token) { %>
            <div class="error-message">
                This reset link is invalid or has expired. 
                <br><br>
                <a href="/forgot-password" style="color: var(--primary-red); text-decoration: underline;">Request a new reset link</a>
            </div>
        <% } else { %>

        <form action="/reset-password" method="POST" id="resetForm">
            <% if (typeof token !== 'undefined' && token) { %>
                <input type="hidden" name="token" value="<%= token %>">
            <% } %>
            
            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        placeholder="enter your new password"
                    >
                    <span class="password-toggle" onclick="togglePassword('password')">👁</span>
                </div>
                <div class="field-error" id="passwordError"></div>
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        id="confirmPassword" 
                        name="confirmPassword" 
                        placeholder="Re-enter password"
                    >
                    <span class="password-toggle" onclick="togglePassword('confirmPassword')">👁</span>
                </div>
                <div class="field-error" id="confirmPasswordError"></div>
            </div>

            <button type="submit" class="update-btn" id="updateBtn">Update Password</button>
        </form>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        function togglePassword(fieldId) {
            const passwordInput = document.getElementById(fieldId);
            const toggle = passwordInput.nextElementSibling;
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggle.textContent = '👁️';
            } else {
                passwordInput.type = 'password';
                toggle.textContent = '👁';
            }
        }

        function showFieldError(fieldId, message) {
            const errorElement = document.getElementById(fieldId + 'Error');
            errorElement.textContent = message;
            errorElement.classList.add('show');
        }

        function clearFieldError(fieldId) {
            const errorElement = document.getElementById(fieldId + 'Error');
            errorElement.textContent = '';
            errorElement.classList.remove('show');
        }

        function clearServerError() {
            const serverError = document.querySelector('.error-message');
            if (serverError && !serverError.textContent.includes('Invalid reset link') && !serverError.textContent.includes('expired')) {
                serverError.style.display = 'none';
            }
        }

        document.getElementById('password').addEventListener('input', function() {
            clearFieldError('password');
            clearServerError();
        });

        document.getElementById('confirmPassword').addEventListener('input', function() {
            clearFieldError('confirmPassword');
            clearServerError();
        });

        document.getElementById('resetForm').addEventListener('submit', (e) => {
            e.preventDefault();
            
            clearFieldError('password');
            clearFieldError('confirmPassword');

            const password = document.getElementById('password').value.trim();
            const confirmPassword = document.getElementById('confirmPassword').value.trim();
            let isValid = true;

            if (!password) {
                showFieldError('password', 'Password is required');
                isValid = false;
            }
            else if (password.length < 8) {
                showFieldError('password', 'Password must be at least 8 characters long');
                isValid = false;
            }
            else {
                const hasUpperCase = /[A-Z]/.test(password);
                const hasLowerCase = /[a-z]/.test(password);
                const hasNumber = /[0-9]/.test(password);
                const hasSpecialChar = /[!@#$%^&*(),.?":{}|<>]/.test(password);

                if (!hasUpperCase || !hasLowerCase || !hasNumber || !hasSpecialChar) {
                    showFieldError('password', 'Password must contain at least one uppercase letter, one lowercase letter, one number, and one special character');
                    isValid = false;
                }
            }

            if (!confirmPassword) {
                showFieldError('confirmPassword', 'Please confirm your password');
                isValid = false;
            }
            else if (password !== confirmPassword) {
                showFieldError('confirmPassword', 'Passwords do not match');
                isValid = false;
            }

            if (isValid) {
                e.target.submit();
            } else {
                Toastify({
                    text: "Please fix the errors in the form",
                    duration: 3000,
                    gravity: "top",
                    position: "center",
                    style: {
                        background: "#c33",
                    }
                }).showToast();
            }
        });
    </script>
</body>
</html>
