<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/wishlist.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Shade swatches on wishlist cards */
        .shade-swatches {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 8px 0 12px;
        }
        .shade-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 1.5px solid rgba(0,0,0,0.10);
            display: inline-block;
            box-shadow: 0 1px 4px rgba(0,0,0,0.18);
            cursor: default;
            transition: transform 0.15s;
        }
        .shade-dot:hover {
            transform: scale(1.25);
        }
    </style>
    <script src="/js/prevent-back.js"></script>
</head>
<body>
    <%- include('../partials/navbar') %>

    <script>
        // Highlight wishlist icon in navbar
        document.addEventListener('DOMContentLoaded', function() {
            const wishlistLink = document.querySelector('.header-icons a[href="/wishlist"]');
            if (wishlistLink) {
                wishlistLink.classList.add('active-wishlist');
                const icon = wishlistLink.querySelector('i');
                if (icon) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                }
            }
        });
    </script>

    <!-- Wishlist Header -->
    <section class="wishlist-header">
        <h1 class="wishlist-title">My Wishlist</h1>
        <p class="wishlist-subtitle">A curated selection of your most desired rituals.</p>
    </section>

    <!-- Wishlist Content -->
    <section class="wishlist-content">
        <% if (wishlist && wishlist.products && wishlist.products.length > 0) { %>
            <div class="wishlist-grid">
                <% wishlist.products.forEach(product => { %>
                    <%
                        const firstVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
                        const availableVariant = product.variants && product.variants.length > 0 
                            ? (product.variants.find(v => v.quantity > 0) || product.variants[0]) 
                            : null;
                        const isOutOfStock = !product.variants || product.variants.length === 0 || product.variants.every(v => v.quantity === 0);
                        const productImage = firstVariant && firstVariant.images && firstVariant.images.length > 0 ? firstVariant.images[0] : '/images/placeholder.png';
                        const salePrice = firstVariant ? firstVariant.salePrice : null;
                        const regularPrice = firstVariant ? firstVariant.regularPrice : null;
                        const hasDiscount = salePrice && regularPrice && salePrice < regularPrice;
                    %>
                    <div class="wishlist-item" data-product-id="<%= product._id %>">
                        <button class="remove-wishlist-btn" onclick="removeFromWishlist('<%= product._id %>')">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="wishlist-image">
                            <img src="<%= productImage %>" 
                                 alt="<%= product.productName %>">
                        </div>
                        <div class="wishlist-details">
                            <h3 class="wishlist-product-name"><%= product.productName %></h3>
                            <p class="wishlist-product-brand" style="font-family: 'Inter', sans-serif; font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; margin: 5px 0;"><%= product.brand %></p>
                            
                            <% if (product.variants && product.variants.length > 0) { %>
                                <div class="shade-swatches">
                                    <% product.variants.forEach(v => { %>
                                        <span class="shade-dot"
                                              style="background-color: <%= v.hexCode && v.hexCode.trim() ? v.hexCode : '#cccccc' %>;"
                                              title="<%= v.color %>"></span>
                                    <% }) %>
                                </div>
                            <% } %>

                            <p class="wishlist-product-price">
                                <% if (salePrice) { %>
                                    ₹<%= salePrice.toFixed(2) %>
                                    <% if (hasDiscount) { %>
                                        <span style="text-decoration: line-through; color: #999; font-size: 12px; margin-left: 5px;">
                                            ₹<%= regularPrice.toFixed(2) %>
                                        </span>
                                    <% } %>
                                <% } else { %>
                                    N/A
                                <% } %>
                            </p>
                            <% if (product.status === 'INACTIVE') { %>
                                <span class="product-unavailable-label">PRODUCT UNAVAILABLE</span>
                            <% } else { %>
                                <button class="wishlist-add-cart-btn" 
                                        onclick="addToCartFromWishlist('<%= product._id %>', '<%= availableVariant ? availableVariant._id : '' %>')"
                                        <%= isOutOfStock ? 'disabled' : '' %>>
                                    <%= isOutOfStock ? 'OUT OF STOCK' : 'ADD TO CART' %>
                                </button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty Wishlist Message -->
            <div class="empty-wishlist">
                <i class="fas fa-heart-broken"></i>
                <h2>Your Wishlist is Empty</h2>
                <p>Discover our exquisite collection and add your favorites.</p>
                <button class="browse-btn" onclick="window.location.href='/products'">
                    BROWSE COLLECTIONS
                </button>
            </div>
        <% } %>
    </section>

    <%- include('../partials/footer') %>

    <script>
        // Remove item from wishlist
        function removeFromWishlist(productId) {
            Swal.fire({
                title: 'Remove from Wishlist?',
                text: 'Remove this item from wishlist?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#999',
                confirmButtonText: 'Yes, Remove',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (!result.isConfirmed) {
                    return;
                }
                
                // Send AJAX request
                fetch('/wishlist/remove/' + productId, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ 
                            toast: true, 
                            position: 'top-end', 
                            icon: 'success', 
                            title: 'Removed from wishlist', 
                            showConfirmButton: false, 
                            timer: 2500,
                            timerProgressBar: true
                        });
                        // Reload page to show updated wishlist
                        setTimeout(() => window.location.reload(), 2500);
                    } else {
                        Swal.fire({ 
                            toast: true, 
                            position: 'top-end', 
                            icon: 'error', 
                            title: data.message || 'Failed to remove from wishlist', 
                            showConfirmButton: false, 
                            timer: 2500,
                            timerProgressBar: true
                        });
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    Swal.fire({ 
                        toast: true, 
                        position: 'top-end', 
                        icon: 'error', 
                        title: 'Failed to remove from wishlist', 
                        showConfirmButton: false, 
                        timer: 2500,
                        timerProgressBar: true
                    });
                });
            });
        }

        // Add to cart from wishlist
        function addToCartFromWishlist(productId, variantId) {
            if (!variantId) {
                Swal.fire({ 
                    toast: true, 
                    position: 'top-end', 
                    icon: 'warning', 
                    title: 'No shade or variant available for this product', 
                    showConfirmButton: false, 
                    timer: 2500,
                    timerProgressBar: true
                });
                return;
            }
            // Send AJAX request to add to cart
            fetch('/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    productId: productId,
                    variantId: variantId,
                    quantity: 1
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({ 
                        toast: true, 
                        position: 'top-end', 
                        icon: 'success', 
                        title: 'Product added to cart!', 
                        showConfirmButton: false, 
                        timer: 2500,
                        timerProgressBar: true
                    });
                    // Product will be automatically removed from wishlist by backend
                    setTimeout(() => window.location.reload(), 2500);
                } else {
                    Swal.fire({ 
                        toast: true, 
                        position: 'top-end', 
                        icon: 'error', 
                        title: data.message || 'Failed to add to cart', 
                        showConfirmButton: false, 
                        timer: 2500,
                        timerProgressBar: true
                    });
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Swal.fire({ 
                    toast: true, 
                    position: 'top-end', 
                    icon: 'error', 
                    title: 'Failed to add to cart', 
                    showConfirmButton: false, 
                    timer: 2500,
                    timerProgressBar: true
                });
            });
        }
    </script>
</body>
</html>
