<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/wishlist.css">
    <script src="/js/prevent-back.js"></script>
</head>
<body>
    <%- include('../partials/navbar') %>

    <script>
        // Highlight wishlist icon in navbar
        document.addEventListener('DOMContentLoaded', function() {
            const wishlistLink = document.querySelector('.header-icons a[href="/wishlist"]');
            if (wishlistLink) {
                wishlistLink.classList.add('active-wishlist');
                const icon = wishlistLink.querySelector('i');
                if (icon) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                }
            }
        });
    </script>

    <!-- Wishlist Header -->
    <section class="wishlist-header">
        <h1 class="wishlist-title">My Wishlist</h1>
        <p class="wishlist-subtitle">A curated selection of your most desired rituals.</p>
    </section>

    <!-- Wishlist Content -->
    <section class="wishlist-content">
        <% if (wishlist && wishlist.products && wishlist.products.length > 0) { %>
            <div class="wishlist-grid">
                <% wishlist.products.forEach(product => { %>
                    <div class="wishlist-item" data-product-id="<%= product._id %>">
                        <button class="remove-wishlist-btn" onclick="removeFromWishlist('<%= product._id %>')">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="wishlist-image">
                            <img src="<%= product.images && product.images[0] ? product.images[0] : '/images/placeholder.png' %>" 
                                 alt="<%= product.name %>">
                        </div>
                        <div class="wishlist-details">
                            <h3 class="wishlist-product-name"><%= product.name %></h3>
                            <p class="wishlist-product-brand" style="font-family: 'Inter', sans-serif; font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; margin: 5px 0;"><%= product.brand %></p>
                            <p class="wishlist-product-price">
                                ₹<%= product.discountPrice || product.price %>
                                <% if (product.discountPrice && product.discountPrice < product.price) { %>
                                    <span style="text-decoration: line-through; color: #999; font-size: 12px; margin-left: 5px;">
                                        ₹<%= product.price %>
                                    </span>
                                <% } %>
                            </p>
                            <button class="wishlist-add-cart-btn" 
                                    onclick="addToCartFromWishlist('<%= product._id %>')"
                                    <%= product.stock === 0 ? 'disabled' : '' %>>
                                <%= product.stock === 0 ? 'OUT OF STOCK' : 'ADD TO CART' %>
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty Wishlist Message -->
            <div class="empty-wishlist">
                <i class="fas fa-heart-broken"></i>
                <h2>Your Wishlist is Empty</h2>
                <p>Discover our exquisite collection and add your favorites.</p>
                <button class="browse-btn" onclick="window.location.href='/products'">
                    BROWSE COLLECTIONS
                </button>
            </div>
        <% } %>
    </section>

    <%- include('../partials/footer') %>

    <script>
        // Remove item from wishlist
        function removeFromWishlist(productId) {
            if (!confirm('Remove this item from wishlist?')) {
                return;
            }
            
            // Send AJAX request
            fetch('/wishlist/remove/' + productId, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Reload page to show updated wishlist
                    window.location.reload();
                } else {
                    alert(data.message || 'Failed to remove from wishlist');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to remove from wishlist');
            });
        }

        // Add to cart from wishlist
        function addToCartFromWishlist(productId) {
            // Send AJAX request to add to cart
            fetch('/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    productId: productId,
                    quantity: 1
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Product added to cart!');
                    // Product will be automatically removed from wishlist by backend
                    window.location.reload();
                } else {
                    alert(data.message || 'Failed to add to cart');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to add to cart');
            });
        }
    </script>
</body>
</html>
