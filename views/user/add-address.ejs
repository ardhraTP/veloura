<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Address - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            background-color: var(--bg-beige);
            -webkit-font-smoothing: antialiased;
        }

        /* Header */
        header {
            background: transparent;
            padding: 30px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .header-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .header-center a {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s ease;
        }

        .header-center a:hover {
            color: var(--primary-red);
        }

        .header-icons {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .header-icons a {
            color: var(--text-dark);
            font-size: 16px;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .header-icons a:hover {
            color: var(--primary-red);
        }

        /* Main Container */
        .main-container {
            display: flex;
            max-width: 1300px;
            margin: 20px auto 80px;
            gap: 60px;
            padding: 0 80px;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: fit-content;
            background: var(--white);
            border-radius: 20px;
            padding: 30px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        }

        .profile-section {
            text-align: center;
            padding-bottom: 25px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            background: #e8e4df;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
        }

        .profile-avatar i {
            font-size: 32px;
            color: #a09d98;
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 500;
            color: var(--primary-red);
        }

        .sidebar-menu {
            list-style: none;
            padding: 15px 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 25px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .sidebar-menu a i {
            width: 20px;
            font-size: 14px;
            color: var(--text-light);
        }

        .sidebar-menu a:hover {
            color: var(--primary-red);
            background-color: #fcfcfc;
        }

        .sidebar-menu a:hover i {
            color: var(--primary-red);
        }

        .sidebar-menu a.active {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .sidebar-menu a.active i {
            color: var(--white);
        }

        .logout-btn {
            margin: 20px 25px 0 25px;
            padding: 12px;
            background-color: #d32f2f;
            color: var(--white);
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            width: calc(100% - 50px);
            transition: background-color 0.3s ease;
        }

        .logout-btn:hover {
            background-color: #b71c1c;
        }

        /* Content Area */
        .content-area {
            flex: 1;
            background: var(--white);
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 500;
            color: var(--primary-red);
            margin-bottom: 30px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s ease;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary-red);
        }

        .form-group input.error-input,
        .form-group select.error-input,
        .form-group textarea.error-input {
            border-color: #d32f2f;
        }

        .error-text {
            color: #d32f2f;
            font-size: 11px;
            margin-top: 5px;
            display: none;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-primary {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .btn-primary:hover {
            background-color: #40131b;
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-light);
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background-color: #f5f5f5;
        }

        /* Footer */
        footer {
            background-color: var(--box-beige);
            padding: 60px 80px 40px;
            margin-top: 80px;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            max-width: 100%;
        }

        .footer-about {
            flex: 0 0 30%;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 600;
            color: var(--primary-red);
            margin-bottom: 25px;
        }

        .footer-links-container {
            display: flex;
            gap: 100px;
        }

        .footer-column h4 {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            color: var(--primary-red);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column ul li {
            margin-bottom: 15px;
        }

        .footer-column ul li a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 12px;
            transition: color 0.3s ease;
        }

        .footer-column ul li a:hover {
            color: var(--primary-red);
        }

        /* Responsive */
        @media (max-width: 992px) {
            .main-container {
                flex-direction: column;
                padding: 0 40px;
            }
            .sidebar {
                width: 100%;
            }
            .form-row {
                grid-template-columns: 1fr;
            }
            header {
                padding: 20px 40px;
            }
            .footer-content {
                flex-direction: column;
                gap: 50px;
            }
            .footer-links-container {
                flex-wrap: wrap;
                gap: 50px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <!-- Header -->
    <header>
        <a href="/home" class="logo">Veloura</a>
        <div class="header-center">
            <a href="/home">Home</a>
            <a href="/products">Collections</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="header-icons">
            <a href="/wishlist" title="Wishlist"><i class="far fa-heart"></i></a>
            <a href="/cart" title="Cart"><i class="fas fa-shopping-bag"></i></a>
            <a href="/profile" title="Profile"><i class="far fa-user"></i></a>
        </div>
    </header>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="profile-section">
                <div class="profile-avatar">
                    <i class="far fa-user"></i>
                </div>
                <div class="profile-name">Ardra</div>
            </div>

            <ul class="sidebar-menu">
                <li><a href="/profile"><i class="far fa-user-circle"></i> Account Overview</a></li>
                <li><a href="/profile/orders"><i class="fas fa-box"></i> My Orders</a></li>
                <li><a href="/profile/addresses" class="active"><i class="fas fa-map-marker-alt"></i> Manage Addresses</a></li>
                <li><a href="/profile/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                <li><a href="/profile/password"><i class="fas fa-lock"></i> Password</a></li>
                <li><a href="/wishlist"><i class="far fa-heart"></i> Wishlist</a></li>
            </ul>

            <button class="logout-btn" onclick="confirmLogout()">Log Out</button>
        </aside>

        <!-- Content Area -->
        <main class="content-area">
            <h1 class="page-title">Add New Address</h1>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message" style="background-color: #fee; color: #c33; padding: 12px 15px; border-radius: 6px; margin-bottom: 20px; border-left: 3px solid #c33;">
                    <%= error %>
                </div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message" style="background-color: #efe; color: #2a7c2a; padding: 12px 15px; border-radius: 6px; margin-bottom: 20px; border-left: 3px solid #2a7c2a;">
                    <%= success %>
                </div>
            <% } %>

            <form action="/profile/addresses/add" method="POST" id="addAddressForm" novalidate>
                <div class="form-group">
                    <label for="fullName">Full Name *</label>
                    <input type="text" id="fullName" name="fullName" placeholder="Enter full name">
                    <div class="error-text" id="fullNameError"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="phone">Phone Number *</label>
                        <input type="tel" id="phone" name="phone" placeholder="Enter phone number">
                        <div class="error-text" id="phoneError"></div>
                    </div>

                    <div class="form-group">
                        <label for="pincode">Pincode *</label>
                        <input type="text" id="pincode" name="pincode" placeholder="Enter pincode">
                        <div class="error-text" id="pincodeError"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="address">Address *</label>
                    <textarea id="address" name="address" placeholder="House No., Building Name, Street, Area"></textarea>
                    <div class="error-text" id="addressError"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="city">City *</label>
                        <input type="text" id="city" name="city" placeholder="Enter city">
                        <div class="error-text" id="cityError"></div>
                    </div>

                    <div class="form-group">
                        <label for="state">State *</label>
                        <input type="text" id="state" name="state" placeholder="Enter state">
                        <div class="error-text" id="stateError"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="addressType">Address Type *</label>
                    <select id="addressType" name="addressType">
                        <option value="">Select address type</option>
                        <option value="home">Home</option>
                        <option value="work">Work</option>
                    </select>
                    <div class="error-text" id="addressTypeError"></div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='/profile/addresses'">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Address</button>
                </div>
            </form>
        </main>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-about">
                <div class="footer-brand">Veloura</div>
            </div>

            <div class="footer-links-container">
                <div class="footer-column">
                    <h4>Brands</h4>
                    <ul>
                        <li><a href="#">MAC Cosmetics</a></li>
                        <li><a href="#">Maybelline</a></li>
                        <li><a href="#">Lakme</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Contact</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Track Order</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Account</h4>
                    <ul>
                        <li><a href="#">My Account</a></li>
                        <li><a href="/login">Login / Register</a></li>
                        <li><a href="#">Cart</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script>
        function showError(fieldId, message) {
            const field = document.getElementById(fieldId);
            const errorDiv = document.getElementById(fieldId + 'Error');
            field.classList.add('error-input');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
        }

        function clearErrors() {
            const inputs = document.querySelectorAll('.error-input');
            const errorTexts = document.querySelectorAll('.error-text');
            inputs.forEach(input => input.classList.remove('error-input'));
            errorTexts.forEach(text => {
                text.style.display = 'none';
                text.textContent = '';
            });
        }

        // Form validation
        document.getElementById('addAddressForm').addEventListener('submit', function(e) {
            clearErrors();
            let hasError = false;

            const fullName = document.getElementById('fullName').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const pincode = document.getElementById('pincode').value.trim();
            const address = document.getElementById('address').value.trim();
            const city = document.getElementById('city').value.trim();
            const state = document.getElementById('state').value.trim();
            const addressType = document.getElementById('addressType').value;

            // Full name validation (only letters and spaces, 2-50 characters)
            if (!fullName) { 
                showError('fullName', 'Please enter your full name'); 
                hasError = true; 
            } else if (!/^[a-zA-Z\s]{2,50}$/.test(fullName)) { 
                showError('fullName', 'Name must be 2-50 characters and contain only letters'); 
                hasError = true; 
            }

            // Phone validation
            if (!phone) { 
                showError('phone', 'Please enter your phone number'); 
                hasError = true; 
            } else if (!/^[0-9]{10}$/.test(phone)) { 
                showError('phone', 'Please enter a valid 10-digit phone number'); 
                hasError = true; 
            }
            
            // Pincode validation
            if (!pincode) { 
                showError('pincode', 'Please enter your pincode'); 
                hasError = true; 
            } else if (!/^[0-9]{6}$/.test(pincode)) { 
                showError('pincode', 'Please enter a valid 6-digit pincode'); 
                hasError = true; 
            }
            
            // Address validation (10-200 characters)
            if (!address) { 
                showError('address', 'Please enter your address'); 
                hasError = true; 
            } else if (address.length < 10) { 
                showError('address', 'Address must be at least 10 characters'); 
                hasError = true; 
            } else if (address.length > 200) { 
                showError('address', 'Address must not exceed 200 characters'); 
                hasError = true; 
            }
            
            // City validation (only letters and spaces, 2-50 characters)
            if (!city) { 
                showError('city', 'Please enter your city'); 
                hasError = true; 
            } else if (!/^[a-zA-Z\s]{2,50}$/.test(city)) { 
                showError('city', 'City must be 2-50 characters and contain only letters'); 
                hasError = true; 
            }

            // State validation (only letters and spaces, 2-50 characters)
            if (!state) { 
                showError('state', 'Please enter your state'); 
                hasError = true; 
            } else if (!/^[a-zA-Z\s]{2,50}$/.test(state)) { 
                showError('state', 'State must be 2-50 characters and contain only letters'); 
                hasError = true; 
            }

            if (!addressType) { 
                showError('addressType', 'Please select an address type'); 
                hasError = true; 
            }

            if (hasError) {
                e.preventDefault();
                return false;
            }

            return true;
        });

        // Real-time validation
        document.getElementById('fullName').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
            if (this.value.length > 50) this.value = this.value.slice(0, 50);
        });

        document.getElementById('phone').addEventListener('input', function(e) {
            this.value = this.value.replace(/\D/g, '');
            if (this.value.length > 10) this.value = this.value.slice(0, 10);
        });

        document.getElementById('pincode').addEventListener('input', function(e) {
            this.value = this.value.replace(/\D/g, '');
            if (this.value.length > 6) this.value = this.value.slice(0, 6);
        });

        document.getElementById('address').addEventListener('input', function(e) {
            if (this.value.length > 200) this.value = this.value.slice(0, 200);
        });

        document.getElementById('city').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
            if (this.value.length > 50) this.value = this.value.slice(0, 50);
        });

        document.getElementById('state').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
            if (this.value.length > 50) this.value = this.value.slice(0, 50);
        });

        function confirmLogout() {
            Swal.fire({
                title: 'Logging Out?',
                text: 'Are you sure you want to log out of Veloura?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Yes, Log Out',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) window.location.href = '/logout';
            });
        }
    </script>
</body>
</html>
