<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Account - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/sidebar.css">
    <link rel="stylesheet" href="/css/profile.css">
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <!-- Header -->
    <%- include('../partials/navbar') %>

    <!-- Main Container -->
    <div class="main-container">
        <%- include('../partials/profile-sidebar') %>

        <!-- Content Area -->
        <main class="content-area">
            <h2 class="section-title">Account Overview</h2>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message" style="background-color: #efe; color: #2a7c2a; padding: 12px 15px; border-radius: 6px; margin-bottom: 20px; border-left: 3px solid #2a7c2a;">
                    <%= success %>
                </div>
            <% } %>

            <div class="profile-info">
                <div class="info-row">
                    <div class="info-label">Full Name</div>
                    <div class="info-value"><%= user.name %></div>
                </div>

                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value"><%= user.email %></div>
                </div>

                <div class="info-row">
                    <div class="info-label">Phone Number</div>
                    <div class="info-value"><%= user.phone %></div>
                </div>
            </div>

            <button class="edit-profile-btn" onclick="window.location.href='/profile/edit'">Edit Profile</button>
        </main>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
