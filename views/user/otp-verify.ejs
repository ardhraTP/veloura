<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }


        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .otp-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .otp-wrapper {
            background: var(--white);
            border-radius: 20px;
            padding: 60px 80px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .verification-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 15px;
        }

        .verification-subtitle {
            font-size: 14px;
            color: var(--text-light);
            margin-bottom: 50px;
            line-height: 1.6;
        }

        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 40px;
        }

        .otp-input {
            width: 55px;
            height: 55px;
            border: 2px solid var(--border-color);
            border-radius: 10px;
            text-align: center;
            font-size: 22px;
            font-weight: 600;
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
        }

        .otp-input:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(107, 44, 62, 0.1);
        }

        .otp-input::-webkit-outer-spin-button,
        .otp-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .otp-input[type=number] {
            -moz-appearance: textfield;
        }

        .verify-btn {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-bottom: 25px;
        }

        .verify-btn:hover {
            background-color: #552330;
        }

        .verify-btn:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }

        .resend-section {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 25px;
        }

        .resend-link {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }

        .resend-link:hover {
            text-decoration: underline;
        }

        .resend-link.disabled {
            color: #999;
            cursor: not-allowed;
            pointer-events: none;
        }

        .timer {
            color: var(--primary-red);
            font-weight: 600;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
        }

        .success-message {
            background-color: #efe;
            color: #3c3;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #3c3;
        }

        footer {
            background-color: var(--box-beige);
            padding: 40px 20px;
            border-top: 1px solid var(--border-color);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: start;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 400;
            color: var(--text-dark);
        }

        .footer-links {
            display: flex;
            gap: 80px;
        }

        .footer-column h4 {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            color: var(--text-dark);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column ul li {
            margin-bottom: 8px;
        }

        .footer-column ul li a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 13px;
            transition: color 0.3s ease;
        }

        .footer-column ul li a:hover {
            color: var(--primary-red);
        }

        @media (max-width: 768px) {
            .otp-wrapper {
                padding: 40px 30px;
            }

            .otp-inputs {
                gap: 10px;
            }

            .otp-input {
                width: 45px;
                height: 45px;
                font-size: 18px;
            }

            .verification-title {
                font-size: 32px;
            }

            .footer-content {
                flex-direction: column;
                gap: 30px;
            }

            .footer-links {
                gap: 40px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <div class="otp-container">
        <div class="otp-wrapper">
            <h1 class="verification-title">Verification</h1>
            <p class="verification-subtitle">
                We've sent a 6-digit verification code to your email address.
            </p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message"><%= success %></div>
            <% } %>

            <form action="/verify-otp" method="POST" id="otpForm">
                <div class="otp-inputs">
                    <input type="number" class="otp-input" maxlength="1" id="otp1" name="otp1" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp2" name="otp2" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp3" name="otp3" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp4" name="otp4" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp5" name="otp5" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp6" name="otp6" required>
                </div>

                <button type="submit" class="verify-btn" id="verifyBtn">Verify & Proceed</button>
            </form>

            <div class="resend-section">
                Didn't receive the code? 
                <a href="#" class="resend-link" id="resendLink" onclick="resendOTP(event)">
                    Resend Code (<span class="timer" id="timer">60</span>s)
                </a>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer-content">
            <div class="footer-brand">Veloura</div>
            <div class="footer-links">
                <div class="footer-column">
                    <h4>Brands</h4>
                    <ul>
                        <li><a href="#">MAC Cosmetics</a></li>
                        <li><a href="#">Maybelline</a></li>
                        <li><a href="#">Lakme</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Contact</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Track Order</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Account</h4>
                    <ul>
                        <li><a href="#">My Account</a></li>
                        <li><a href="/login">Login / Register</a></li>
                        <li><a href="#">Cart</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // OTP Input Auto-focus and Navigation
        const otpInputs = document.querySelectorAll('.otp-input');
        
        otpInputs.forEach((input, index) => {
            // Move to next input on input
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1) {
                    if (index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                }
                
                // Limit to single digit
                if (e.target.value.length > 1) {
                    e.target.value = e.target.value.slice(0, 1);
                }
            });

            // Handle backspace
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });

            // Handle paste
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').slice(0, 6);
                const digits = pastedData.split('');
                
                digits.forEach((digit, i) => {
                    if (otpInputs[i]) {
                        otpInputs[i].value = digit;
                    }
                });
                
                if (digits.length === 6) {
                    otpInputs[5].focus();
                }
            });
        });

        // Auto-focus first input on page load
        window.addEventListener('load', () => {
            otpInputs[0].focus();
        });

        // Resend OTP Timer
        let timeLeft = 60;
        let timerInterval;

        function startTimer() {
            const timerElement = document.getElementById('timer');
            const resendLink = document.getElementById('resendLink');
            
            resendLink.classList.add('disabled');
            
            timerInterval = setInterval(() => {
                timeLeft--;
                timerElement.textContent = timeLeft;
                
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    resendLink.classList.remove('disabled');
                    resendLink.innerHTML = 'Resend Code';
                    timeLeft = 60;
                }
            }, 1000);
        }

        function resendOTP(event) {
            event.preventDefault();
            
            if (timeLeft < 60) {
                return;
            }
            
            // Make AJAX call to resend OTP
            fetch('/resend-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Toastify({
                        text: "OTP has been resent to your email!",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#4CAF50",
                        stopOnFocus: true
                    }).showToast();
                    startTimer();
                } else {
                    Toastify({
                        text: data.message || "Failed to resend OTP",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#f44336",
                        stopOnFocus: true
                    }).showToast();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Toastify({
                    text: "Failed to resend OTP. Please try again.",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
            });
        }

        // Start timer on page load
        startTimer();

        // Form submission
        document.getElementById('otpForm').addEventListener('submit', (e) => {
            const otp = Array.from(otpInputs).map(input => input.value).join('');
            
            if (otp.length !== 6) {
                e.preventDefault();
                Toastify({
                    text: "Please enter all 6 digits",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
            }
        });
    </script>
</body>
</html>
