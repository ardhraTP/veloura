<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            background-color: var(--bg-beige);
            -webkit-font-smoothing: antialiased;
        }

        /* Header */
        header {
            background: transparent;
            padding: 30px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .header-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .header-center a {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s ease;
        }

        .header-center a:hover {
            color: var(--primary-red);
        }

        .header-icons {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .header-icons a {
            color: var(--text-dark);
            font-size: 16px;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .header-icons a:hover {
            color: var(--primary-red);
        }

        /* Main Container */
        .main-container {
            display: flex;
            max-width: 1300px;
            margin: 20px auto 80px;
            gap: 60px;
            padding: 0 80px;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: fit-content;
            background: var(--white);
            border-radius: 20px;
            padding: 30px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        }

        .profile-section {
            text-align: center;
            padding-bottom: 25px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            background: #e8e4df;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
        }

        .profile-avatar i {
            font-size: 32px;
            color: #a09d98;
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 500;
            color: var(--primary-red);
        }

        .sidebar-menu {
            list-style: none;
            padding: 15px 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 25px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .sidebar-menu a i {
            width: 20px;
            font-size: 14px;
            color: var(--text-light);
        }

        .sidebar-menu a:hover {
            color: var(--primary-red);
            background-color: #fcfcfc;
        }

        .sidebar-menu a:hover i {
            color: var(--primary-red);
        }

        .sidebar-menu a.active {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .sidebar-menu a.active i {
            color: var(--white);
        }

        .logout-btn {
            margin: 20px 25px 0 25px;
            padding: 12px;
            background-color: #d32f2f;
            color: var(--white);
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            width: calc(100% - 50px);
            transition: background-color 0.3s ease;
        }

        .logout-btn:hover {
            background-color: #b71c1c;
        }

        /* Content Area */
        .content-area {
            flex: 1;
            background: var(--white);
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 500;
            color: var(--primary-red);
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper {
            position: relative;
        }

        .form-group input {
            width: 100%;
            padding: 12px 45px 12px 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s ease;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--primary-red);
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--text-light);
            font-size: 16px;
        }

        .password-toggle:hover {
            color: var(--primary-red);
        }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-primary {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .btn-primary:hover {
            background-color: #40131b;
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-light);
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background-color: #f5f5f5;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 12px 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
            font-size: 13px;
        }

        .success-message {
            background-color: #efe;
            color: #2a7c2a;
            padding: 12px 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            border-left: 3px solid #2a7c2a;
            font-size: 13px;
        }

        .field-error {
            color: #c33;
            font-size: 11px;
            margin-top: 5px;
            min-height: 16px;
            display: block;
        }

        .input-error {
            border-color: #c33 !important;
        }

        /* Footer */
        footer {
            background-color: var(--box-beige);
            padding: 60px 80px 40px;
            margin-top: 80px;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            max-width: 100%;
        }

        .footer-about {
            flex: 0 0 30%;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 600;
            color: var(--primary-red);
            margin-bottom: 25px;
        }

        .footer-links-container {
            display: flex;
            gap: 100px;
        }

        .footer-column h4 {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            color: var(--primary-red);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column ul li {
            margin-bottom: 15px;
        }

        .footer-column ul li a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 12px;
            transition: color 0.3s ease;
        }

        .footer-column ul li a:hover {
            color: var(--primary-red);
        }

        /* Responsive */
        @media (max-width: 992px) {
            .main-container {
                flex-direction: column;
                padding: 0 40px;
            }
            .sidebar {
                width: 100%;
            }
            header {
                padding: 20px 40px;
            }
            .footer-content {
                flex-direction: column;
                gap: 50px;
            }
            .footer-links-container {
                flex-wrap: wrap;
                gap: 50px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <!-- Header -->
    <header>
        <a href="/home" class="logo">Veloura</a>
        <div class="header-center">
            <a href="/home">Home</a>
            <a href="/products">Collections</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="header-icons">
            <a href="/wishlist" title="Wishlist"><i class="far fa-heart"></i></a>
            <a href="/cart" title="Cart"><i class="fas fa-shopping-bag"></i></a>
            <a href="/profile" title="Profile"><i class="far fa-user"></i></a>
        </div>
    </header>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="profile-section">
                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="profile-name">User</div>
            </div>

            <ul class="sidebar-menu">
                <li><a href="/profile"><i class="far fa-user-circle"></i> Account Overview</a></li>
                <li><a href="/profile/orders"><i class="fas fa-box"></i> My Orders</a></li>
                <li><a href="/profile/addresses"><i class="fas fa-map-marker-alt"></i> Manage Addresses</a></li>
                <li><a href="/profile/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                <li><a href="/profile/password" class="active"><i class="fas fa-lock"></i> Password</a></li>
                <li><a href="/wishlist"><i class="far fa-heart"></i> Wishlist</a></li>
            </ul>

            <button class="logout-btn" onclick="confirmLogout()">Log Out</button>
        </aside>

        <!-- Content Area -->
        <main class="content-area">
            <h1 class="page-title">Change Password</h1>

            <% if (!hasPassword) { %>
            <div style="background:#fff8e8;border-left:3px solid #e6a817;padding:12px 16px;border-radius:0 6px 6px 0;margin-bottom:24px;font-size:12px;color:#7a5800;display:flex;align-items:center;gap:10px;">
                <i class="fab fa-google" style="font-size:15px;"></i>
                <span>You signed in with Google. Set a password below to enable email login as well.</span>
            </div>
            <% } %>

            <div id="messageContainer"></div>

            <form id="changePasswordForm">
                <% if (hasPassword) { %>
                <div class="form-group" id="currentPasswordGroup">
                    <label for="currentPassword">Current Password *</label>
                    <div class="input-wrapper">
                        <input type="password" id="currentPassword" name="currentPassword" placeholder="Enter current password">
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('currentPassword')"></i>
                    </div>
                    <div class="field-error" id="currentPasswordError"></div>
                </div>
                <% } %>

                <div class="form-group">
                    <label for="newPassword">New Password *</label>
                    <div class="input-wrapper">
                        <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password">
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('newPassword')"></i>
                    </div>
                    <div class="field-error" id="newPasswordError"></div>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password *</label>
                    <div class="input-wrapper">
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password">
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('confirmPassword')"></i>
                    </div>
                    <div class="field-error" id="confirmPasswordError"></div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='/profile'">Cancel</button>
                    <button type="submit" class="btn btn-primary">Change Password</button>
                </div>
            </form>
        </main>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-about">
                <div class="footer-brand">Veloura</div>
            </div>

            <div class="footer-links-container">
                <div class="footer-column">
                    <h4>Brands</h4>
                    <ul>
                        <li><a href="#">MAC Cosmetics</a></li>
                        <li><a href="#">Maybelline</a></li>
                        <li><a href="#">Lakme</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Contact</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Track Order</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Account</h4>
                    <ul>
                        <li><a href="#">My Account</a></li>
                        <li><a href="/login">Login / Register</a></li>
                        <li><a href="#">Cart</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script>
        function togglePassword(fieldId) {
            const passwordInput = document.getElementById(fieldId);
            const toggle = passwordInput.nextElementSibling;
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggle.className = 'fas fa-eye-slash password-toggle';
            } else {
                passwordInput.type = 'password';
                toggle.className = 'fas fa-eye password-toggle';
            }
        }

        function showMessage(message, isError = false) {
            const container = document.getElementById('messageContainer');
            const messageClass = isError ? 'error-message' : 'success-message';
            container.innerHTML = `<div class="${messageClass}">${message}</div>`;
        }

        function showFieldError(fieldId, message) {
            const errorElement = document.getElementById(fieldId + 'Error');
            const inputElement = document.getElementById(fieldId);
            if (errorElement && inputElement) {
                errorElement.textContent = message;
                inputElement.classList.add('input-error');
            }
        }

        function clearFieldError(fieldId) {
            const errorElement = document.getElementById(fieldId + 'Error');
            const inputElement = document.getElementById(fieldId);
            if (errorElement && inputElement) {
                errorElement.textContent = '';
                inputElement.classList.remove('input-error');
            }
        }

        function clearAllErrors() {
            const currentPasswordEl = document.getElementById('currentPassword');
            if (currentPasswordEl) {
                clearFieldError('currentPassword');
            }
            clearFieldError('newPassword');
            clearFieldError('confirmPassword');
        }

        const allInputs = document.querySelectorAll('#changePasswordForm input[type="password"]');
        allInputs.forEach(input => {
            input.addEventListener('input', clearAllErrors);
        });

        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            e.preventDefault();

            clearAllErrors();

            const currentPasswordEl = document.getElementById('currentPassword');
            const newPasswordEl = document.getElementById('newPassword');
            const confirmPasswordEl = document.getElementById('confirmPassword');

            const currentPassword = currentPasswordEl ? currentPasswordEl.value.trim() : '';
            const newPassword = newPasswordEl.value.trim();
            const confirmPassword = confirmPasswordEl.value.trim();

            let hasError = false;

            if (currentPasswordEl && !currentPassword) {
                showFieldError('currentPassword', 'Current password is required');
                hasError = true;
            }

            if (!newPassword) {
                showFieldError('newPassword', 'New password is required');
                hasError = true;
            } else if (newPassword.length < 8) {
                showFieldError('newPassword', 'Password must be at least 8 characters long');
                hasError = true;
            } else {
                const hasUpperCase = /[A-Z]/.test(newPassword);
                const hasLowerCase = /[a-z]/.test(newPassword);
                const hasNumber = /[0-9]/.test(newPassword);
                const hasSpecialChar = /[!@#$%^&*(),.?":{}|<>]/.test(newPassword);

                if (!hasUpperCase || !hasLowerCase || !hasNumber || !hasSpecialChar) {
                    showFieldError('newPassword', 'Password must contain uppercase, lowercase, number, and special character');
                    hasError = true;
                }
            }

            if (!confirmPassword) {
                showFieldError('confirmPassword', 'Please confirm your new password');
                hasError = true;
            } else if (newPassword && confirmPassword !== newPassword) {
                showFieldError('confirmPassword', 'Passwords do not match');
                hasError = true;
            }

            if (currentPasswordEl && currentPassword && newPassword && currentPassword === newPassword) {
                showFieldError('newPassword', 'New password must be different from current password');
                hasError = true;
            }

            if (hasError) {
                return;
            }

            const payload = { newPassword, confirmPassword };
            if (currentPasswordEl) {
                payload.currentPassword = currentPassword;
            }

            fetch('/profile/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showMessage(data.message);
                    document.getElementById('changePasswordForm').reset();
                } else {
                    showMessage(data.message, true);
                }
            })
            .catch(error => {
                showMessage('Something went wrong. Please try again.', true);
            });
        });

        function confirmLogout() {
            Swal.fire({
                title: 'Logging Out?',
                text: 'Are you sure you want to log out of Veloura?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Yes, Log Out',
                cancelButtonText: 'Cancel',
                borderRadius: '12px'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/logout';
                }
            });
        }
    </script>
</body>
</html>