<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email Change - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .otp-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .otp-wrapper {
            background: var(--white);
            border-radius: 20px;
            padding: 60px 80px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .verification-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 15px;
        }

        .verification-subtitle {
            font-size: 14px;
            color: var(--text-light);
            margin-bottom: 50px;
            line-height: 1.6;
        }

        .new-email {
            color: var(--primary-red);
            font-weight: 600;
        }

        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 40px;
        }

        .otp-input {
            width: 55px;
            height: 55px;
            border: 2px solid var(--border-color);
            border-radius: 10px;
            text-align: center;
            font-size: 22px;
            font-weight: 600;
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
        }

        .otp-input:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(107, 44, 62, 0.1);
        }

        .otp-input::-webkit-outer-spin-button,
        .otp-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .otp-input[type=number] {
            -moz-appearance: textfield;
        }

        .verify-btn {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-bottom: 25px;
        }

        .verify-btn:hover {
            background-color: #552330;
        }

        .verify-btn:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }

        .resend-section {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 25px;
        }

        .resend-link {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }

        .resend-link:hover {
            text-decoration: underline;
        }

        .resend-link.disabled {
            color: #999;
            cursor: not-allowed;
            pointer-events: none;
        }

        .timer {
            color: var(--primary-red);
            font-weight: 600;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
        }

        .success-message {
            background-color: #efe;
            color: #3c3;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #3c3;
        }

        .back-link {
            margin-top: 20px;
        }

        .back-link a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 13px;
        }

        .back-link a:hover {
            color: var(--primary-red);
            text-decoration: underline;
        }

        .time-remaining {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 15px;
        }

        .expired-message {
            background-color: #fff3cd;
            color: #856404;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 3px solid #ffc107;
        }

        @media (max-width: 768px) {
            .otp-wrapper {
                padding: 40px 30px;
            }

            .otp-inputs {
                gap: 10px;
            }

            .otp-input {
                width: 45px;
                height: 45px;
                font-size: 18px;
            }

            .verification-title {
                font-size: 32px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <div class="otp-container">
        <div class="otp-wrapper">
            <h1 class="verification-title">Verify New Email</h1>
            <p class="verification-subtitle">
                We've sent a 6-digit verification code to your new email address:<br>
                <span class="new-email"><%= newEmail %></span>
            </p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message"><%= success %></div>
            <% } %>

            <form action="/profile/verify-email-change" method="POST" id="otpForm">
                <div class="otp-inputs">
                    <input type="number" class="otp-input" maxlength="1" id="otp1" name="otp1" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp2" name="otp2" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp3" name="otp3" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp4" name="otp4" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp5" name="otp5" required>
                    <input type="number" class="otp-input" maxlength="1" id="otp6" name="otp6" required>
                </div>

                <button type="submit" class="verify-btn" id="verifyBtn">Verify & Update Email</button>
            </form>

            <div class="time-remaining">
                <span id="timeRemaining">Time remaining: <span class="timer" id="timeLeft">5:00</span></span>
            </div>

            <div class="resend-section">
                Didn't receive the code? 
                <a href="#" class="resend-link" id="resendLink" onclick="resendOTP(event)">
                    <span id="resendText">Resend Code (<span class="timer" id="resendTimer">60</span>s)</span>
                </a>
            </div>

            <div class="back-link">
                <a href="/profile/edit">← Back to Profile</a>
            </div>
        </div>
    </div>

    <script>
        const otpInputs = document.querySelectorAll('.otp-input');
        
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1) {
                    if (index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                }
                
                if (e.target.value.length > 1) {
                    e.target.value = e.target.value.slice(0, 1);
                }
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });

            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').slice(0, 6);
                const digits = pastedData.split('');
                
                digits.forEach((digit, i) => {
                    if (otpInputs[i]) {
                        otpInputs[i].value = digit;
                    }
                });
                
                if (digits.length === 6) {
                    otpInputs[5].focus();
                }
            });
        });

        window.addEventListener('load', () => {
            otpInputs[0].focus();
        });

        function getStoredEmailOTPEndTime() {
            const stored = localStorage.getItem('emailOTPTimerEndTime');
            return stored ? parseInt(stored) : null;
        }

        function setStoredEmailOTPEndTime(endTime) {
            localStorage.setItem('emailOTPTimerEndTime', endTime.toString());
        }

        function clearStoredEmailOTPEndTime() {
            localStorage.removeItem('emailOTPTimerEndTime');
        }

        function getStoredEmailResendEndTime() {
            const stored = localStorage.getItem('emailResendTimerEndTime');
            return stored ? parseInt(stored) : null;
        }

        function setStoredEmailResendEndTime(endTime) {
            localStorage.setItem('emailResendTimerEndTime', endTime.toString());
        }

        function clearStoredEmailResendEndTime() {
            localStorage.removeItem('emailResendTimerEndTime');
        }

        let otpTimeLeft = 5 * 60; 
        let otpTimerInterval;

        function startOTPTimer() {
            const timeLeftElement = document.getElementById('timeLeft');
            const timeRemainingElement = document.getElementById('timeRemaining');
            
            const storedEndTime = getStoredEmailOTPEndTime();
            const now = Date.now();
            
            if (storedEndTime && storedEndTime > now) {
                otpTimeLeft = Math.ceil((storedEndTime - now) / 1000);
            } else {
                otpTimeLeft = 5 * 60;
                setStoredEmailOTPEndTime(now + (5 * 60 * 1000));
            }
            
            otpTimerInterval = setInterval(() => {
                otpTimeLeft--;
                
                const minutes = Math.floor(otpTimeLeft / 60);
                const seconds = otpTimeLeft % 60;
                timeLeftElement.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                
                if (otpTimeLeft <= 0) {
                    clearInterval(otpTimerInterval);
                    timeRemainingElement.innerHTML = '<div class="expired-message">OTP has expired. Please request a new one.</div>';
                    document.getElementById('verifyBtn').disabled = true;
                    clearStoredEmailOTPEndTime();
                    
                    otpInputs.forEach(input => {
                        input.disabled = true;
                        input.style.backgroundColor = '#f5f5f5';
                    });
                }
            }, 1000);
        }

        let resendTimeLeft = 60;
        let resendTimerInterval;

        function startResendTimer() {
            const resendTimerElement = document.getElementById('resendTimer');
            const resendLink = document.getElementById('resendLink');
            const resendText = document.getElementById('resendText');
            
            const storedEndTime = getStoredEmailResendEndTime();
            const now = Date.now();
            
            if (storedEndTime && storedEndTime > now) {
                resendTimeLeft = Math.ceil((storedEndTime - now) / 1000);
            } else {
                resendTimeLeft = 60;
                setStoredEmailResendEndTime(now + (60 * 1000));
            }
            
            resendTimerElement.textContent = resendTimeLeft;
            resendLink.classList.add('disabled');
            
            resendTimerInterval = setInterval(() => {
                resendTimeLeft--;
                resendTimerElement.textContent = resendTimeLeft;
                
                if (resendTimeLeft <= 0) {
                    clearInterval(resendTimerInterval);
                    resendLink.classList.remove('disabled');
                    resendText.innerHTML = 'Resend Code';
                    clearStoredEmailResendEndTime();
                    resendTimeLeft = 60;
                }
            }, 1000);
        }

        function resendOTP(event) {
            event.preventDefault();
            
            if (resendTimeLeft < 60) {
                return;
            }
            
            fetch('/profile/resend-email-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Toastify({
                        text: "OTP has been resent to your new email!",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#4CAF50",
                        stopOnFocus: true
                    }).showToast();
                    
                    clearInterval(resendTimerInterval);
                    const newResendEndTime = Date.now() + (60 * 1000);
                    setStoredEmailResendEndTime(newResendEndTime);
                    resendTimeLeft = 60;
                    startResendTimer();
                    
                    clearInterval(otpTimerInterval);
                    const newOTPEndTime = Date.now() + (5 * 60 * 1000);
                    setStoredEmailOTPEndTime(newOTPEndTime);
                    otpTimeLeft = 5 * 60;
                    startOTPTimer();
                    
                    document.getElementById('verifyBtn').disabled = false;
                    otpInputs.forEach(input => {
                        input.disabled = false;
                        input.style.backgroundColor = '';
                        input.value = '';
                    });
                    otpInputs[0].focus();
                } else {
                    Toastify({
                        text: data.message || "Failed to resend OTP",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#f44336",
                        stopOnFocus: true
                    }).showToast();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Toastify({
                    text: "Failed to resend OTP. Please try again.",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
            });
        }

        startOTPTimer();
        startResendTimer();

        window.addEventListener('beforeunload', () => {
            clearInterval(otpTimerInterval);
            clearInterval(resendTimerInterval);
        });

        document.getElementById('otpForm').addEventListener('submit', (e) => {
            const otp = Array.from(otpInputs).map(input => input.value).join('');
            
            if (otp.length !== 6) {
                e.preventDefault();
                Toastify({
                    text: "Please enter all 6 digits",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
                return;
            }
            
            if (otpTimeLeft <= 0) {
                e.preventDefault();
                Toastify({
                    text: "OTP has expired. Please request a new one.",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
                return;
            }
        });
    </script>
</body>
</html>