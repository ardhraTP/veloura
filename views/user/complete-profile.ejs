<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Your Profile - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #efece5;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, .logo { font-family: 'Playfair Display', serif; }

        header {
            position: absolute;
            top: 0; left: 0; right: 0;
            padding: 30px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
        }

        .logo {
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .page-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 120px 20px 60px;
        }

        .card-wrapper {
            display: flex;
            background: var(--white);
            border-radius: 20px;
            overflow: hidden;
            max-width: 900px;
            width: 100%;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            min-height: 480px;
        }

        .brand-side {
            flex: 1;
            background-color: var(--primary-red);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px 40px;
            color: var(--white);
            text-align: center;
        }

        .brand-side .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-size: 32px;
        }

        .brand-side h2 {
            font-size: 28px;
            font-weight: 500;
            margin-bottom: 16px;
            line-height: 1.2;
        }

        .brand-side p {
            font-size: 13px;
            color: rgba(255,255,255,0.75);
            line-height: 1.7;
            font-weight: 300;
        }

        .google-badge {
            margin-top: 30px;
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.12);
            border-radius: 30px;
            padding: 8px 18px;
            font-size: 11px;
            letter-spacing: 0.5px;
        }

        .form-side {
            flex: 1;
            padding: 60px 70px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title {
            font-size: 36px;
            font-weight: 500;
            color: var(--primary-red);
            margin-bottom: 8px;
            line-height: 1.1;
        }

        .form-subtitle {
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 40px;
            letter-spacing: 0.3px;
        }

        .user-greeting {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fdf8f0;
            border-left: 3px solid var(--primary-red);
            padding: 12px 16px;
            margin-bottom: 32px;
            border-radius: 0 6px 6px 0;
        }

        .user-greeting i { color: var(--primary-red); font-size: 14px; }
        .user-greeting span { font-size: 12px; color: var(--text-dark); font-weight: 500; }

        .form-group { margin-bottom: 28px; }

        .form-group label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper { position: relative; }

        .form-group input {
            width: 100%;
            padding: 15px 0 15px 32px;
            border: none;
            border-bottom: 1px solid #ddd;
            background: transparent;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s ease;
            border-radius: 0;
        }

        .form-group input:focus {
            outline: none;
            border-bottom-color: var(--primary-red);
        }

        .form-group input::placeholder { color: #aaa; font-size: 13px; font-weight: 300; }

        .input-icon {
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            color: #bbb;
            font-size: 13px;
            transition: color 0.3s;
        }

        .form-group input:focus ~ .input-icon { color: var(--primary-red); }

        .hint-text {
            font-size: 10px;
            color: var(--text-light);
            margin-top: 8px;
            letter-spacing: 0.3px;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 12px 15px;
            font-size: 12px;
            margin-bottom: 25px;
            border-left: 3px solid #c33;
        }

        .submit-btn {
            width: 100%;
            padding: 16px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 8px;
        }

        .submit-btn:hover { background-color: #3b1118; }

        /* Footer */
        footer {
            background-color: var(--white);
            padding: 40px 100px 30px;
        }

        .footer-bottom {
            text-align: center;
            font-size: 11px;
            color: var(--text-light);
            padding-top: 20px;
            border-top: 1px solid #eee;
        }

        @media (max-width: 768px) {
            .card-wrapper { flex-direction: column; }
            .brand-side { padding: 40px 30px; }
            .form-side { padding: 40px 30px; }
            header { padding: 20px 30px; }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <header>
        <a href="/" class="logo">Veloura</a>
    </header>

    <div class="page-container">
        <div class="card-wrapper">
            <!-- Brand side -->
            <div class="brand-side">
                <div class="icon-circle">
                    <i class="fas fa-user-check"></i>
                </div>
                <h2>Almost there!</h2>
                <p>Just one more step to complete your Veloura account and start exploring our curated beauty collection.</p>
                <div class="google-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24">
                        <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="rgba(255,255,255,0.7)" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="rgba(255,255,255,0.5)" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="rgba(255,255,255,0.3)" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Signed in with Google
                </div>
            </div>

            <!-- Form side -->
            <div class="form-side">
                <h1 class="form-title">Complete Profile</h1>
                <p class="form-subtitle">We need your phone number to finish setting up your account.</p>

                <div class="user-greeting">
                    <i class="fas fa-circle-check"></i>
                    <span>Welcome, <%= user.name %>! Your Google account is connected.</span>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-message"><%= error %></div>
                <% } %>

                <form action="/complete-profile" method="POST">
                    <div class="form-group">
                        <label for="phone">Mobile Number</label>
                        <div class="input-wrapper">
                            <input
                                type="tel"
                                id="phone"
                                name="phone"
                                placeholder="Enter your 10-digit mobile number"
                                pattern="[0-9]{10}"
                                maxlength="10"
                                required
                                autofocus
                                oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                            >
                            <i class="fas fa-phone input-icon"></i>
                        </div>
                        <p class="hint-text">Enter a valid 10-digit mobile number</p>
                    </div>

                    <button type="submit" class="submit-btn" id="complete-profile-btn">
                        <i class="fas fa-check" style="margin-right:8px;"></i>Complete My Account
                    </button>
                </form>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer-bottom">
            &copy; <%= new Date().getFullYear() %> Veloura. All rights reserved.
        </div>
    </footer>
</body>
</html>
