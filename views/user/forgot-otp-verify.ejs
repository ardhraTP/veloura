<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }


        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .otp-container {
            background: transparent;
            max-width: 600px;
            width: 100%;
            text-align: center;
        }

        .verification-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 15px;
        }

        .verification-subtitle {
            font-size: 14px;
            color: var(--text-light);
            margin-bottom: 50px;
            line-height: 1.6;
        }

        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
        }

        .otp-input {
            width: 60px;
            height: 60px;
            border: 2px solid var(--border-color);
            border-radius: 10px;
            text-align: center;
            font-size: 24px;
            font-weight: 600;
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            background-color: var(--white);
        }

        .otp-input:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(107, 44, 62, 0.1);
        }

        .otp-input::-webkit-outer-spin-button,
        .otp-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .otp-input[type=number] {
            -moz-appearance: textfield;
        }

        .verify-btn {
            width: 100%;
            max-width: 400px;
            padding: 14px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-bottom: 25px;
        }

        .verify-btn:hover {
            background-color: #552330;
        }

        .verify-btn:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }

        .resend-section {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 25px;
        }

        .resend-link {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }

        .resend-link:hover {
            text-decoration: underline;
        }

        .resend-link.disabled {
            color: #999;
            cursor: not-allowed;
            pointer-events: none;
        }

        .timer {
            color: var(--primary-red);
            font-weight: 600;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

        .success-message {
            background-color: #efe;
            color: #2a7c2a;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #2a7c2a;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

        @media (max-width: 768px) {
            .otp-inputs {
                gap: 12px;
            }

            .otp-input {
                width: 50px;
                height: 50px;
                font-size: 20px;
            }

            .verification-title {
                font-size: 32px;
            }
        }
    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>
    <div class="otp-container">
        <h1 class="verification-title">Verification</h1>
        <p class="verification-subtitle">
            We've sent a 4-digit verification code to your email address.
        </p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-message"><%= success %></div>
        <% } %>

        <form action="/forgot-otp-verify" method="POST" id="otpForm">
            <div class="otp-inputs">
                <input type="number" class="otp-input" maxlength="1" id="otp1" name="otp1" required>
                <input type="number" class="otp-input" maxlength="1" id="otp2" name="otp2" required>
                <input type="number" class="otp-input" maxlength="1" id="otp3" name="otp3" required>
                <input type="number" class="otp-input" maxlength="1" id="otp4" name="otp4" required>
            </div>

            <button type="submit" class="verify-btn" id="verifyBtn">Verify & Proceed</button>
        </form>

        <div class="resend-section">
            Didn't receive the code? 
            <a href="#" class="resend-link" id="resendLink" onclick="resendOTP(event)">
                Resend Code (<span class="timer" id="timer">60</span>s)
            </a>
        </div>
    </div>

    <script>
        const otpInputs = document.querySelectorAll('.otp-input');
        
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1) {
                    if (index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                }
                
                if (e.target.value.length > 1) {
                    e.target.value = e.target.value.slice(0, 1);
                }
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });

            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').slice(0, 4);
                const digits = pastedData.split('');
                
                digits.forEach((digit, i) => {
                    if (otpInputs[i]) {
                        otpInputs[i].value = digit;
                    }
                });
                
                if (digits.length === 4) {
                    otpInputs[3].focus();
                }
            });
        });

        window.addEventListener('load', () => {
            otpInputs[0].focus();
        });

        function getStoredForgotTimerEndTime() {
            const stored = localStorage.getItem('forgotOTPTimerEndTime');
            return stored ? parseInt(stored) : null;
        }

        function setStoredForgotTimerEndTime(endTime) {
            localStorage.setItem('forgotOTPTimerEndTime', endTime.toString());
        }

        function clearStoredForgotTimerEndTime() {
            localStorage.removeItem('forgotOTPTimerEndTime');
        }

        let timeLeft = 60;
        let timerInterval;

        function startTimer() {
            const timerElement = document.getElementById('timer');
            const resendLink = document.getElementById('resendLink');
            
            const storedEndTime = getStoredForgotTimerEndTime();
            const now = Date.now();
            
            if (storedEndTime && storedEndTime > now) {
                timeLeft = Math.ceil((storedEndTime - now) / 1000);
            } else {
                timeLeft = 60;
                setStoredForgotTimerEndTime(now + (60 * 1000));
            }
            
            timerElement.textContent = timeLeft;
            resendLink.classList.add('disabled');
            
            timerInterval = setInterval(() => {
                timeLeft--;
                timerElement.textContent = timeLeft;
                
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    resendLink.classList.remove('disabled');
                    resendLink.innerHTML = 'Resend Code';
                    clearStoredForgotTimerEndTime();
                    timeLeft = 60;
                }
            }, 1000);
        }

        function resendOTP(event) {
            event.preventDefault();
            
            if (timeLeft < 60) {
                return;
            }
            
            fetch('/resend-forgot-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Toastify({
                        text: "OTP has been resent to your email!",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#4CAF50",
                        stopOnFocus: true
                    }).showToast();
                    
                    clearInterval(timerInterval);
                    const newEndTime = Date.now() + (60 * 1000);
                    setStoredForgotTimerEndTime(newEndTime);
                    timeLeft = 60;
                    startTimer();
                } else {
                    Toastify({
                        text: data.message || "Failed to resend OTP",
                        duration: 3000,
                        gravity: "top",
                        position: "right",
                        backgroundColor: "#f44336",
                        stopOnFocus: true
                    }).showToast();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Toastify({
                    text: "Failed to resend OTP. Please try again.",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
            });
        }

        startTimer();

        window.addEventListener('beforeunload', () => {
            clearInterval(timerInterval);
        });

        document.getElementById('otpForm').addEventListener('submit', (e) => {
            const otp = Array.from(otpInputs).map(input => input.value).join('');
            
            if (otp.length !== 4) {
                e.preventDefault();
                Toastify({
                    text: "Please enter all 4 digits",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#f44336",
                    stopOnFocus: true
                }).showToast();
            }
        });
    </script>
</body>
</html>
