<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Veloura</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            --box-beige: #f4f1ec;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }


        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-beige);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .header {
            padding: 30px 50px;
            background: transparent;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 400;
            color: var(--text-dark);
            text-decoration: none;
            letter-spacing: 2px;
        }

        .forgot-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .forgot-wrapper {
            background: var(--white);
            border-radius: 20px;
            padding: 60px 80px;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 30px;
            text-align: left;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-light);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s ease;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--primary-red);
        }

        .form-group input::placeholder {
            color: #aaa;
            font-size: 13px;
        }

        .reset-btn {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-red);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .reset-btn:hover {
            background-color: #552330;
        }

        .back-to-login {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 20px;
        }

        .back-to-login a {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 600;
        }

        .back-to-login a:hover {
            text-decoration: underline;
        }

        .error-message {
            background-color: #fee;
            color: #c33;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #c33;
            text-align: left;
        }

        .success-message {
            background-color: #efe;
            color: #2a7c2a;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            border-left: 3px solid #2a7c2a;
            text-align: left;
        }

        .arrow-icon {
            font-size: 16px;
        }

        @media (max-width: 768px) {
            .header {
                padding: 20px 30px;
            }

            .forgot-wrapper {
                padding: 40px 30px;
            }

            .brand-title {
                font-size: 28px;
            }

            .page-title {
                font-size: 26px;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="logo">VELOURA</a>
    </div>

    <div class="forgot-container">
        <div class="forgot-wrapper">
            <h1 class="brand-title">VELOURA</h1>
            <h2 class="page-title">Forgot Password</h2>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message"><%= success %></div>
            <% } %>

            <form action="/forgot-password" method="POST">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="example@gmail.com" 
                        required
                    >
                </div>

                <button type="submit" class="reset-btn">
                    Send Reset Email
                    <span class="arrow-icon">→</span>
                </button>
            </form>

            <div class="back-to-login">
                <a href="/login">Back to Login</a>
            </div>
        </div>
    </div>
</body>
</html>
