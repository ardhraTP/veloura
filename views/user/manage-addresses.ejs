<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Addresses - Veloura</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #fdfbf9;
            /* Lighter beige for the overall page */
            --box-beige: #f4f1ec;
            /* Slightly darker beige for cards */
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
            --border-color: #e8e4df;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            background-color: var(--bg-beige);
            -webkit-font-smoothing: antialiased;
        }

        /* Header */
        header {
            background: transparent;
            padding: 30px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .header-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .header-center a {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s ease;
        }

        .header-center a:hover {
            color: var(--primary-red);
        }

        .header-icons {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .header-icons a {
            color: var(--text-dark);
            font-size: 16px;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .header-icons a:hover {
            color: var(--primary-red);
        }

        /* Main Container */
        .main-container {
            display: flex;
            max-width: 1300px;
            margin: 20px auto 80px;
            gap: 60px;
            padding: 0 80px;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: fit-content;
            background: var(--white);
            border-radius: 20px;
            padding: 30px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        }

        .profile-section {
            text-align: center;
            padding-bottom: 25px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            background: #e8e4df;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
        }

        .profile-avatar i {
            font-size: 32px;
            color: #a09d98;
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 500;
            color: var(--primary-red);
        }

        .sidebar-menu {
            list-style: none;
            padding: 15px 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 25px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .sidebar-menu a i {
            width: 20px;
            font-size: 14px;
            color: var(--text-light);
        }

        .sidebar-menu a:hover {
            color: var(--primary-red);
            background-color: #fcfcfc;
        }

        .sidebar-menu a:hover i {
            color: var(--primary-red);
        }

        .sidebar-menu a.active {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .sidebar-menu a.active i {
            color: var(--white);
        }

        .logout-btn {
            margin: 20px 25px 0 25px;
            padding: 12px;
            background-color: #d32f2f;
            color: var(--white);
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            width: calc(100% - 50px);
            transition: background-color 0.3s ease;
        }

        .logout-btn:hover {
            background-color: #b71c1c;
        }

        /* Content Area */
        .content-area {
            flex: 1;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            font-weight: 500;
            color: var(--primary-red);
            letter-spacing: -0.5px;
        }

        .add-address-btn {
            background-color: var(--primary-red);
            color: var(--white);
            padding: 12px 24px;
            border: none;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background-color 0.3s ease;
        }

        .add-address-btn:hover {
            background-color: #40131b;
        }

        /* Address Grid */
        .address-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
        }

        .address-card {
            background: var(--box-beige);
            padding: 30px;
            position: relative;
        }

        .address-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            padding: 4px 12px;
            font-size: 9px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            background-color: #ebd7a4;
            /* Soft gold/yellow badge */
            color: #634f19;
        }

        .address-name {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 500;
            color: var(--text-dark);
            margin-bottom: 15px;
        }

        .address-details {
            font-size: 12px;
            color: var(--text-light);
            line-height: 1.8;
            margin-bottom: 25px;
        }

        .address-actions {
            display: flex;
            gap: 20px;
            padding-top: 15px;
            border-top: 1px solid rgba(0, 0, 0, 0.08);
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: none;
            border: none;
            color: var(--primary-red);
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
            transition: color 0.3s ease;
        }

        .action-btn:hover {
            color: #40131b;
        }

        /* Footer */
        footer {
            background-color: var(--box-beige);
            padding: 60px 80px 40px;
            margin-top: 80px;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            max-width: 100%;
        }

        .footer-about {
            flex: 0 0 30%;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 600;
            color: var(--primary-red);
            margin-bottom: 25px;
        }

        .footer-links-container {
            display: flex;
            gap: 100px;
        }

        .footer-column h4 {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            color: var(--primary-red);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column ul li {
            margin-bottom: 15px;
        }

        .footer-column ul li a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 12px;
            transition: color 0.3s ease;
        }

        .footer-column ul li a:hover {
            color: var(--primary-red);
        }

        /* Responsive */
        @media (max-width: 992px) {
            .main-container {
                flex-direction: column;
                padding: 0 40px;
            }

            .sidebar {
                width: 100%;
            }

            .address-grid {
                grid-template-columns: 1fr;
            }

            header {
                padding: 20px 40px;
            }

            .footer-content {
                flex-direction: column;
                gap: 50px;
            }

            .footer-links-container {
                flex-wrap: wrap;
                gap: 50px;
            }
        }
    </style>
    <script src="/js/prevent-back.js"></script>
</head>

<body>
    <!-- Header -->
    <header>
        <a href="/home" class="logo">Veloura</a>
        <div class="header-center">
            <a href="/home">Home</a>
            <a href="/products">Collections</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="header-icons">
            <a href="/wishlist" title="Wishlist"><i class="far fa-heart"></i></a>
            <a href="/cart" title="Cart"><i class="fas fa-shopping-bag"></i></a>
            <a href="/profile" title="Profile"><i class="far fa-user"></i></a>
        </div>
    </header>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="profile-section">
                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="profile-name">Ardra</div>
            </div>

            <ul class="sidebar-menu">
                <li><a href="/profile"><i class="far fa-user-circle"></i> Account Overview</a></li>
                <li><a href="/profile/orders"><i class="fas fa-box"></i> My Orders</a></li>
                <li><a href="/profile/addresses" class="active"><i class="fas fa-map-marker-alt"></i> Manage
                        Addresses</a></li>
                <li><a href="/profile/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                <li><a href="/profile/password"><i class="fas fa-lock"></i> Password</a></li>
                <li><a href="/wishlist"><i class="far fa-heart"></i> Wishlist</a></li>
            </ul>

            <button class="logout-btn" onclick="confirmLogout()">Log Out</button>
        </aside>

        <!-- Content Area -->
        <main class="content-area">
            <div class="page-header">
                <h1 class="page-title">Manage Addresses</h1>
               

                <button class="add-address-btn" onclick="window.location.href='/profile/addresses/add'">
                    <i class="fas fa-plus"></i> Add New Address
                </button>
            </div>

            <div class="address-grid">
                <% if (addresses && addresses.length> 0) { %>
                    <% addresses.forEach(address=> { %>
                        <div class="address-card">
                            <span class="address-badge">
                                <%= address.addressType.charAt(0).toUpperCase() + address.addressType.slice(1) %>
                            </span>
                            <% if (address.isDefault) { %>
                                <span class="address-badge"
                                    style="background-color: #d4edda; color: #155724; top: 20px; right: 80px;">Default</span>
                                <% } %>
                                    <h3 class="address-name">
                                        <%= address.fullName %>
                                    </h3>
                                    <p class="address-details">
                                        <%= address.address %><br>
                                            <%= address.city %>, <%= address.state %> - <%= address.pincode %><br>
                                                        Phone: <%= address.phone %>
                                    </p>
                                    <div class="address-actions">
                                        <button class="action-btn"
                                            onclick="window.location.href='/profile/addresses/edit/<%= address._id %>'">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <% if (!address.isDefault) { %>
                                            <button class="action-btn"
                                                onclick="setDefaultAddress('<%= address._id %>')">
                                                <i class="fas fa-star"></i> Set Default
                                            </button>
                                            <% } %>
                                                <button class="action-btn remove"
                                                    onclick="removeAddress('<%= address._id %>')">
                                                    <i class="fas fa-trash"></i> Remove
                                                </button>
                                    </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <div
                                    style="grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: var(--text-light);">
                                    <i class="fas fa-map-marker-alt"
                                        style="font-size: 48px; margin-bottom: 20px; opacity: 0.3;"></i>
                                    <h3 style="margin-bottom: 10px;">No addresses found</h3>
                                    <p>Add your first address to get started</p>
                                </div>
                                <% } %>
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-about">
                <div class="footer-brand">Veloura</div>
            </div>

            <div class="footer-links-container">
                <div class="footer-column">
                    <h4>Brands</h4>
                    <ul>
                        <li><a href="#">MAC Cosmetics</a></li>
                        <li><a href="#">Maybelline</a></li>
                        <li><a href="#">Lakme</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Contact</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Track Order</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Account</h4>
                    <ul>
                        <li><a href="#">My Account</a></li>
                        <li><a href="/login">Login / Register</a></li>
                        <li><a href="#">Cart</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script>
        function removeAddress(id) {
            Swal.fire({
                title: 'Remove Address?',
                text: 'This address will be permanently deleted.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Yes, Remove',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/profile/addresses/${id}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Address removed', showConfirmButton: false, timer: 2000 });
                                setTimeout(() => window.location.reload(), 2000);
                            } else {
                                Swal.fire('Error', data.message || 'Failed to remove address', 'error');
                            }
                        })
                        .catch(() => Swal.fire('Error', 'Failed to remove address', 'error'));
                }
            });
        }

        function setDefaultAddress(id) {
            fetch(`/profile/addresses/${id}/default`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Default address updated', showConfirmButton: false, timer: 2000 });
                        setTimeout(() => window.location.reload(), 2000);
                    } else {
                        Swal.fire('Error', data.message || 'Failed to update default address', 'error');
                    }
                })
                .catch(() => Swal.fire('Error', 'Failed to update default address', 'error'));
        }

        function confirmLogout() {
            Swal.fire({
                title: 'Logging Out?',
                text: 'Are you sure you want to log out of Veloura?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Yes, Log Out',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) window.location.href = '/logout';
            });
        }
    </script>
</body>

</html>