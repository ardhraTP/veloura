<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Veloura - Landing Page</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-red: #5c1e28;
            --bg-beige: #efece5;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            overflow-x: hidden;
            background-color: var(--white);
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, .logo {
            font-family: 'Playfair Display', serif;
        }

        /* Header */
        header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            background: var(--bg-beige);
            padding: 30px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
        }

        .logo {
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: 0.5px;
        }

        .header-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .header-center a {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s ease;
        }

        .header-center a:hover {
            color: var(--primary-red);
        }

        .header-auth {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .login-btn {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 8px 15px;
            transition: color 0.3s ease;
        }

        .login-btn:hover {
            color: var(--primary-red);
        }

        .signup-btn {
            background-color: var(--primary-red);
            color: var(--white);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 10px 20px;
            border-radius: 3px;
            transition: background-color 0.3s ease;
        }

        .signup-btn:hover {
            background-color: #3b1118;
        }

        /* Hero Section */
        .hero {
            padding-top: 120px;
            background-color: var(--bg-beige);
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 85vh;
            padding-left: 100px;
            padding-right: 0;
            overflow: hidden;
        }

        .hero-content {
            flex: 0 0 35%;
            max-width: 480px;
            z-index: 2;
        }

        .hero-title {
            font-size: 78px;
            font-weight: 500;
            color: var(--primary-red);
            margin-bottom: 25px;
            line-height: 1.05;
            letter-spacing: -1px;
        }

        .hero-description {
            font-size: 14px;
            color: var(--text-dark);
            line-height: 1.8;
            margin-bottom: 40px;
            font-weight: 400;
            max-width: 400px;
        }

        .shop-btn {
            background-color: var(--primary-red);
            color: var(--white);
            padding: 16px 35px;
            border: none;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .shop-btn:hover {
            background-color: #3b1118;
        }

        .hero-image-container {
            flex: 0 0 65%;
            height: 100%;
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .hero-image-container img {
            width: 100%;
            height: auto;
            max-height: 90vh;
            object-fit: cover;
            object-position: left center;
        }

        /* Premium Category Section */
        .premium-section {
            padding: 120px 100px 80px;
            background-color: var(--white);
        }

        .section-header {
            margin-bottom: 60px;
        }

        .section-subtitle {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 500;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 15px;
        }

        .section-title {
            font-size: 42px;
            font-weight: 500;
            color: var(--primary-red);
            letter-spacing: -0.5px;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .product-card {
            background: var(--white);
            cursor: pointer;
            display: flex;
            flex-direction: column;
        }

        .product-image-wrapper {
            width: 100%;
            aspect-ratio: 4/5;
            overflow: hidden;
            margin-bottom: 25px;
            background-color: #f7f7f7;
        }

        .product-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover .product-image-wrapper img {
            transform: scale(1.03);
        }

        .product-brand {
            font-size: 26px;
            font-weight: 500;
            color: var(--primary-red);
            margin-bottom: 8px;
        }

        .product-category {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 500;
        }

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin-top: 80px;
        }

        .pagination-line-container {
            display: flex;
            width: 100px;
            height: 2px;
            background-color: #e5e5e5;
        }

        .pagination-line-active {
            width: 33.33%;
            height: 100%;
            background-color: var(--primary-red);
        }

        .pagination-text {
            font-family: 'Inter', sans-serif;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 2px;
            color: var(--primary-red);
        }

        /* New Collection Banner */
        .collection-banner {
            position: relative;
            background: url('/images/banner_bg.png') center/cover no-repeat;
            padding: 120px 50px;
            text-align: center;
            color: var(--white);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 450px;
        }

        .collection-banner::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(44, 15, 20, 0.4);
            z-index: 1;
        }

        .banner-content {
            position: relative;
            z-index: 2;
            max-width: 600px;
        }

        .banner-subtitle {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 20px;
        }

        .banner-title {
            font-size: 48px;
            font-weight: 500;
            margin-bottom: 25px;
            letter-spacing: -0.5px;
        }

        .banner-description {
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            line-height: 1.8;
            margin-bottom: 35px;
            font-weight: 300;
        }

        .explore-btn {
            background-color: var(--white);
            color: var(--text-dark);
            padding: 16px 40px;
            border: none;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .explore-btn:hover {
            background-color: var(--bg-beige);
        }

        /* Footer */
        footer {
            background-color: var(--white);
            padding: 80px 100px 40px;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            max-width: 100%;
            margin-bottom: 40px;
        }

        .footer-about {
            flex: 0 0 30%;
        }

        .footer-brand {
            font-size: 32px;
            font-weight: 600;
            color: var(--primary-red);
            margin-bottom: 25px;
        }

        .social-links {
            display: flex;
            gap: 15px;
        }

        .social-links a {
            width: 35px;
            height: 35px;
            border: 1px solid var(--text-dark);
            border-radius: 50%;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .social-links a:hover {
            background-color: var(--text-dark);
            color: var(--white);
        }

        .footer-links-container {
            display: flex;
            gap: 100px;
        }

        .footer-column h4 {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            color: var(--primary-red);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column ul li {
            margin-bottom: 15px;
        }

        .footer-column ul li a {
            font-family: 'Inter', sans-serif;
            color: var(--text-light);
            text-decoration: none;
            font-size: 12px;
            font-weight: 400;
            transition: color 0.3s ease;
        }

        .footer-column ul li a:hover {
            color: var(--primary-red);
        }

        /* Responsive */
        @media (max-width: 992px) {
            .hero {
                flex-direction: column;
                padding: 120px 40px 60px;
            }
            
            .hero-content {
                max-width: 100%;
                margin-bottom: 50px;
            }
            
            .product-grid {
                grid-template-columns: 1fr;
            }
            
            .footer-content {
                flex-direction: column;
                gap: 50px;
            }
            
            .footer-links-container {
                flex-wrap: wrap;
                gap: 50px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <a href="/" class="logo">Veloura</a>
        <div class="header-center">
            <a href="/">Home</a>
            <a href="/products">Collections</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="header-auth">
            <a href="/login" class="login-btn">Login</a>
            <a href="/register" class="signup-btn">Sign Up</a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">The Art of the Lip</h1>
            <p class="hero-description">
                Experience a collection where heritage meets haute couture. Pigment as rich as history, textures as soft as velvet.
            </p>
            <button class="shop-btn" onclick="window.location.href='/products'">Discover the Collection</button>
        </div>
        <div class="hero-image-container">
            <img src="/images/hero_bg.png" alt="Hero Lipstick">
        </div>
    </section>

    <!-- Premium Category Section -->
    <section class="premium-section">
        <div class="section-header">
            <p class="section-subtitle">CURATED EXCELLENCE</p>
            <h2 class="section-title">The Premium category</h2>
        </div>

        <div class="product-grid">
            <div class="product-card">
                <div class="product-image-wrapper">
                    <img src="/images/mac_product.png" alt="Mac Cosmetics">
                </div>
                <div class="product-info">
                    <h3 class="product-brand">Mac Cosmetics</h3>
                    <p class="product-category">RETRO VELVET FINISH</p>
                </div>
            </div>

            <div class="product-card">
                <div class="product-image-wrapper">
                    <img src="/images/maybelline_product.png" alt="Maybelline">
                </div>
                <div class="product-info">
                    <h3 class="product-brand">Maybelline</h3>
                    <p class="product-category">LUSTRE SHINE FOCUS</p>
                </div>
            </div>

            <div class="product-card">
                <div class="product-image-wrapper">
                    <img src="/images/lakme_product.png" alt="Lakme">
                </div>
                <div class="product-info">
                    <h3 class="product-brand">Lakme</h3>
                    <p class="product-category">SHEER HYDRATION</p>
                </div>
            </div>
        </div>

        <div class="pagination">
            <div class="pagination-line-container">
                <div class="pagination-line-active"></div>
            </div>
            <span class="pagination-text">01 / 03</span>
        </div>
    </section>

    <!-- New Collection Banner -->
    <section class="collection-banner">
        <div class="banner-content">
            <p class="banner-subtitle">LIMITED EDITION RELEASE</p>
            <h2 class="banner-title">Shop the New Collection</h2>
            <p class="banner-description">
                The Gilded Series: A harmonious blend of Macaroon artisanal waxcraft and contemporary pigment science.
            </p>
            <button class="explore-btn" onclick="window.location.href='/products'">EXPLORE NOW</button>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-about">
                <div class="footer-brand">Veloura</div>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-links-container">
                <div class="footer-column">
                    <h4>BRANDS</h4>
                    <ul>
                        <li><a href="#">MAC Cosmetics</a></li>
                        <li><a href="#">Maybelline</a></li>
                        <li><a href="#">Lakme</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>SUPPORT</h4>
                    <ul>
                        <li><a href="#">Contact</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Track Order</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>ACCOUNT</h4>
                    <ul>
                        <li><a href="#">My Account</a></li>
                        <li><a href="/login">Login/Register</a></li>
                        <li><a href="#">Cart</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
