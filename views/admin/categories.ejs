<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Categories - Veloura Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f5f5;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 40px;
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .breadcrumb {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .breadcrumb span {
            color: #5c1e28;
            font-weight: 600;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: #6b6b6b;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .user-icon {
            width: 24px;
            height: 24px;
            border: 2px solid #5c1e28;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #5c1e28;
        }

        /* Page Title */
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #5c1e28;
            margin-bottom: 40px;
            font-weight: 400;
        }

        /* Table Card */
        .table-card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            margin-bottom: 50px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background-color: #5c1e28;
        }

        th {
            padding: 18px 30px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: white;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        td {
            padding: 22px 30px;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }

        tbody tr:hover {
            background-color: #fafafa;
        }

        .category-name {
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 15px;
            color: #333;
        }

        /* Toggle Switch */
        .toggle-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .toggle-switch {
            position: relative;
            width: 50px;
            height: 26px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: 0.4s;
            border-radius: 26px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #5c1e28;
        }

        input:checked + .slider:before {
            transform: translateX(24px);
        }

        .status-text {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .status-text.listed {
            color: #5c1e28;
        }

        .status-text.unlisted {
            color: #999;
        }

        /* Action buttons container */
        .action-buttons {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        /* Edit Button */
        .edit-btn {
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: #666;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .edit-btn:hover {
            color: #5c1e28;
        }

        /* Delete Button */
        .delete-btn {
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: #666;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .delete-btn:hover {
            color: #d9534f;
        }

        /* Toolbar */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .toolbar-left {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .filter-btn, .search-box {
            padding: 10px 20px;
            border: 1px solid #ddd;
            border-radius: 5px;
            background: white;
            font-size: 13px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
        }

        .search-box {
            width: 250px;
            outline: none;
            transition: border-color 0.3s;
        }

        .search-box:focus {
            border-color: #5c1e28;
        }

        .filter-btn {
            background-color: #5c1e28;
            color: white;
            border: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .filter-btn:hover {
            background-color: #4a1620;
        }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            margin-top: 30px;
            padding-bottom: 20px;
        }

        .page-btn {
            padding: 8px 16px;
            border: 1px solid #ddd;
            background: white;
            color: #333;
            border-radius: 5px;
            cursor: pointer;
            text-decoration: none;
            font-size: 13px;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
        }

        .page-btn:hover, .page-btn.active {
            background-color: #5c1e28;
            color: white;
            border-color: #5c1e28;
        }

        /* Add Category Form */
        .add-category-section {
            margin-top: 60px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            color: #5c1e28;
            margin-bottom: 30px;
            font-weight: 400;
        }

        .form-card {
            background: #faf9f8;
            border-radius: 8px;
            padding: 40px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 25px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #666;
            margin-bottom: 10px;
        }

        .form-input,
        .form-textarea {
            padding: 12px 0;
            border: none;
            border-bottom: 1px solid #ddd;
            background: transparent;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #333;
            outline: none;
            transition: border-color 0.3s;
        }

        .form-input::placeholder,
        .form-textarea::placeholder {
            color: #bbb;
        }

        .form-input:focus,
        .form-textarea:focus {
            border-bottom-color: #5c1e28;
        }

        .form-textarea {
            resize: none;
            min-height: 80px;
        }

        .form-footer {
            margin-top: 40px;
            text-align: center;
        }

        .btn-save {
            padding: 14px 50px;
            background-color: #5c1e28;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-save:hover {
            background-color: #4a1620;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(92, 30, 40, 0.3);
        }

        /* Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.open {
            display: flex;
        }

        .modal-box {
            background: white;
            border-radius: 10px;
            padding: 40px;
            width: 600px;
            max-width: 90vw;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: transparent;
            border: none;
            font-size: 24px;
            color: #999;
            cursor: pointer;
            transition: color 0.3s;
        }

        .modal-close:hover {
            color: #5c1e28;
        }

        .modal-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: #5c1e28;
            margin-bottom: 30px;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        .form-input.input-error,
        .form-textarea.input-error {
            border-bottom-color: #dc3545 !important;
        }

        .field-error {
            color: #dc3545;
            font-size: 11px;
            margin-top: 5px;
            display: none;
            text-align: left;
        }

        .field-error.visible {
            display: block;
        }
    </style>
    <script src="/js/prevent-back.js"></script>
</head>
<body>
    <%- include('../partials/admin/sidebar', { selectedTab: 'categories' }) %>


    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <div class="breadcrumb">
                MANAGEMENT › <span>CATEGORIES</span>
            </div>
        </div>

        <!-- Page Title -->
        <h1 class="page-title">Manage Categories</h1>

        <!-- Toolbar with Search and Clear -->
        <div class="toolbar">
            <div class="toolbar-left">
                <form action="/admin/categories" method="GET" style="display: flex; gap: 15px;">
                    <input type="text" 
                           name="search" 
                           id="searchInput"
                           value="<%= typeof search !== 'undefined' ? search : '' %>" 
                           class="search-box" 
                           placeholder="SEARCH">
                    <button type="submit" class="filter-btn">SEARCH</button>
                    <% if (typeof search !== 'undefined' && search) { %>
                        <a href="/admin/categories" class="filter-btn" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">CLEAR</a>
                    <% } %>
                </form>
            </div>
        </div>

        <!-- Categories Table -->
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>S.NO</th>
                        <th>CATEGORY NAME</th>
                        <th>STATUS</th>
                        <th>ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach((category, index) => { %>
                            <tr>
                                <td><%= (typeof currentPage !== 'undefined' ? currentPage - 1 : 0) * 10 + index + 1 %></td>
                                <td class="category-name"><%= category.name %></td>
                                <td>
                                    <div class="toggle-container">
                                        <label class="toggle-switch">
                                            <input type="checkbox" 
                                                   <%= category.isListed ? 'checked' : '' %>
                                                   onchange="toggleCategory('<%= category._id %>', this)">
                                            <span class="slider"></span>
                                        </label>
                                        <span class="status-text <%= category.isListed ? 'listed' : 'unlisted' %>" 
                                              id="status-<%= category._id %>">
                                            <%= category.isListed ? 'LISTED' : 'UNLISTED' %>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="edit-btn" 
                                                data-id="<%= category._id %>"
                                                data-name="<%= category.name %>"
                                                data-offer="<%= category.offer || '' %>"
                                                data-description="<%= category.description || '' %>"
                                                onclick="openEditModal(this)"
                                                title="Edit Category">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="delete-btn" 
                                                onclick="deleteCategory('<%= category._id %>')"
                                                title="Delete Category">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4">
                                <div class="empty-state">
                                    <p>No categories found. Add your first category below.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %><%= (typeof search !== 'undefined' && search) ? '&search=' + encodeURIComponent(search) : '' %>" class="page-btn">«</a>
                <% } %>
                
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %><%= (typeof search !== 'undefined' && search) ? '&search=' + encodeURIComponent(search) : '' %>" class="page-btn <%= currentPage === i ? 'active' : '' %>">
                        <%= i %>
                    </a>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %><%= (typeof search !== 'undefined' && search) ? '&search=' + encodeURIComponent(search) : '' %>" class="page-btn">»</a>
                <% } %>
            </div>
        <% } %>

        <!-- Add New Category Section -->
        <div class="add-category-section">
            <h2 class="section-title">Add New Category</h2>
            
            <div class="form-card">
                <form action="/admin/categories/add" method="POST" id="addCategoryForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">CATEGORY NAME</label>
                            <input type="text" 
                                   id="addName"
                                   name="name" 
                                   class="form-input" 
                                   placeholder="Enter category name...">
                            <span class="field-error" id="addNameError"></span>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">OFFER</label>
                            <input type="text" 
                                   id="addOffer"
                                   name="offer" 
                                   class="form-input" 
                                   placeholder="e.g. 20% Seasonal Discount">
                            <span class="field-error" id="addOfferError"></span>
                        </div>
                    </div>
                    
                    <div class="form-group full-width">
                        <label class="form-label">COLLECTION DESCRIPTION</label>
                        <textarea id="addDescription"
                                  name="description" 
                                  class="form-textarea" 
                                  placeholder="Describe the collection's essence and target aesthetic..."></textarea>
                        <span class="field-error" id="addDescriptionError"></span>
                    </div>
                    
                    <div class="form-footer">
                        <button type="submit" class="btn-save">SAVE CATEGORY</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <!-- Edit Modal -->
    <div class="modal-overlay" id="editModal">
        <div class="modal-box">
            <button class="modal-close" onclick="closeEditModal()">×</button>
            <h3 class="modal-title">Edit Category</h3>
            
            <form id="editForm" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">CATEGORY NAME</label>
                        <input type="text" 
                               id="editName" 
                               name="name" 
                               class="form-input">
                        <span class="field-error" id="editNameError"></span>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">OFFER</label>
                        <input type="text" 
                               id="editOffer" 
                               name="offer" 
                               class="form-input">
                        <span class="field-error" id="editOfferError"></span>
                    </div>
                </div>
                
                <div class="form-group full-width">
                    <label class="form-label">COLLECTION DESCRIPTION</label>
                    <textarea id="editDescription" 
                              name="description" 
                              class="form-textarea"></textarea>
                    <span class="field-error" id="editDescriptionError"></span>
                </div>
                
                <div class="form-footer">
                    <button type="submit" class="btn-save">UPDATE CATEGORY</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Helpers: show/clear inline field errors
        function showErr(id, errId, show, msg = '') {
            const el = document.getElementById(id);
            const err = document.getElementById(errId);
            if (!el || !err) return;
            el.classList.toggle('input-error', show);
            err.textContent = msg;
            err.classList.toggle('visible', show);
        }

        // Add Category validation logic
        const addForm = document.getElementById('addCategoryForm');
        const addNameInput = document.getElementById('addName');
        const addDescInput = document.getElementById('addDescription');

        if (addNameInput) {
            addNameInput.addEventListener('input', function() {
                if (this.value.trim()) {
                    showErr('addName', 'addNameError', false);
                } else {
                    showErr('addName', 'addNameError', true, 'Category name is required.');
                }
            });
        }

        if (addDescInput) {
            addDescInput.addEventListener('input', function() {
                if (this.value.trim()) {
                    showErr('addDescription', 'addDescriptionError', false);
                } else {
                    showErr('addDescription', 'addDescriptionError', true, 'Collection description is required.');
                }
            });
        }

        if (addForm) {
            addForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const nameValue = addNameInput.value.trim();
                const descValue = addDescInput ? addDescInput.value.trim() : '';

                addNameInput.value = nameValue; // Update input with trimmed value
                if (addDescInput) addDescInput.value = descValue; // Update input with trimmed value

                let isValid = true;

                if (!nameValue) {
                    showErr('addName', 'addNameError', true, 'Category name is required.');
                    isValid = false;
                }
                if (addDescInput && !descValue) {
                    showErr('addDescription', 'addDescriptionError', true, 'Collection description is required.');
                    isValid = false;
                }

                if (!isValid) {
                    if (!nameValue) {
                        addNameInput.focus();
                    } else if (addDescInput && !descValue) {
                        addDescInput.focus();
                    }
                    return false;
                }
                this.submit();
            });
        }

        // Edit Category validation logic
        const editForm = document.getElementById('editForm');
        const editNameInput = document.getElementById('editName');
        const editDescInput = document.getElementById('editDescription');

        if (editNameInput) {
            editNameInput.addEventListener('input', function() {
                if (this.value.trim()) {
                    showErr('editName', 'editNameError', false);
                } else {
                    showErr('editName', 'editNameError', true, 'Category name is required.');
                }
            });
        }

        if (editDescInput) {
            editDescInput.addEventListener('input', function() {
                if (this.value.trim()) {
                    showErr('editDescription', 'editDescriptionError', false);
                } else {
                    showErr('editDescription', 'editDescriptionError', true, 'Collection description is required.');
                }
            });
        }

        if (editForm) {
            editForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const nameValue = editNameInput.value.trim();
                const descValue = editDescInput ? editDescInput.value.trim() : '';

                editNameInput.value = nameValue; // Update input with trimmed value
                if (editDescInput) editDescInput.value = descValue; // Update input with trimmed value

                let isValid = true;

                if (!nameValue) {
                    showErr('editName', 'editNameError', true, 'Category name is required.');
                    isValid = false;
                }
                if (editDescInput && !descValue) {
                    showErr('editDescription', 'editDescriptionError', true, 'Collection description is required.');
                    isValid = false;
                }

                if (!isValid) {
                    if (!nameValue) {
                        editNameInput.focus();
                    } else if (editDescInput && !descValue) {
                        editDescInput.focus();
                    }
                    return false;
                }
                this.submit();
            });
        }

        // Toggle category listing status
        async function toggleCategory(categoryId, checkbox) {
            const statusText = document.getElementById('status-' + categoryId);
            
            // If trying to unlist (checkbox is now unchecked)
            if (!checkbox.checked) {
                // Revert checkbox visually until confirmed
                checkbox.checked = true;
                
                const result = await Swal.fire({
                    title: 'Unlist Category?',
                    text: 'Are you sure you want to unlist this category?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#5c1e28',
                    cancelButtonColor: '#999',
                    confirmButtonText: 'Yes, Unlist',
                    cancelButtonText: 'Cancel'
                });

                if (!result.isConfirmed) {
                    return; // Reverted and cancelled
                }
                
                // Set checked to false and proceed with request
                checkbox.checked = false;
            }
            
            try {
                const response = await fetch(`/admin/categories/${categoryId}/toggle-list`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    if (data.isListed) {
                        statusText.textContent = 'LISTED';
                        statusText.className = 'status-text listed';
                        checkbox.checked = true;
                        
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: 'Category listed successfully!',
                            confirmButtonColor: '#5c1e28',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        statusText.textContent = 'UNLISTED';
                        statusText.className = 'status-text unlisted';
                        checkbox.checked = false;
                    }
                } else {
                    checkbox.checked = !checkbox.checked;
                    if (checkbox.checked) {
                        statusText.textContent = 'LISTED';
                        statusText.className = 'status-text listed';
                    } else {
                        statusText.textContent = 'UNLISTED';
                        statusText.className = 'status-text unlisted';
                    }
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.message || 'Error updating category status',
                        confirmButtonColor: '#5c1e28'
                    });
                }
            } catch (error) {
                checkbox.checked = !checkbox.checked;
                if (checkbox.checked) {
                    statusText.textContent = 'LISTED';
                    statusText.className = 'status-text listed';
                } else {
                    statusText.textContent = 'UNLISTED';
                    statusText.className = 'status-text unlisted';
                }
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Error connecting to server',
                    confirmButtonColor: '#5c1e28'
                });
            }
        }

        // Delete category
        async function deleteCategory(categoryId) {
            const result = await Swal.fire({
                title: 'Delete Category?',
                text: 'Are you sure you want to delete this category?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#999',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            });

            if (!result.isConfirmed) {
                return;
            }

            try {
                const response = await fetch(`/admin/categories/${categoryId}/delete`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Deleted!',
                        text: data.message || 'Category deleted successfully',
                        confirmButtonColor: '#5c1e28',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    window.location.reload();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.message || 'Error deleting category',
                        confirmButtonColor: '#5c1e28'
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Error connecting to server',
                    confirmButtonColor: '#5c1e28'
                });
            }
        }

        // Open edit modal
        function openEditModal(button) {
            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');
            const offer = button.getAttribute('data-offer');
            const description = button.getAttribute('data-description');
            
            document.getElementById('editForm').action = `/admin/categories/${id}/edit`;
            document.getElementById('editName').value = name;
            document.getElementById('editOffer').value = offer;
            document.getElementById('editDescription').value = description;
            
            // Clear any previous validation errors
            showErr('editName', 'editNameError', false);
            showErr('editOffer', 'editOfferError', false);
            showErr('editDescription', 'editDescriptionError', false);
            
            document.getElementById('editModal').classList.add('open');
        }
        
        // Close edit modal
        function closeEditModal() {
            document.getElementById('editModal').classList.remove('open');
        }
        
        // Close modal when clicking outside
        document.getElementById('editModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeEditModal();
            }
        });

        // Show success/error notifications from URL parameters and clear them
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const successMsg = urlParams.get('success');
            const errorMsg = urlParams.get('error');

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: successMsg,
                    confirmButtonColor: '#5c1e28',
                    timer: 3000,
                    showConfirmButton: false
                });
                const remainingParams = Array.from(urlParams.entries())
                    .filter(([key]) => key !== 'success' && key !== 'error')
                    .map(([key, val]) => `${key}=${encodeURIComponent(val)}`)
                    .join('&');
                const newUrl = window.location.pathname + (remainingParams ? '?' + remainingParams : '');
                window.history.replaceState({}, document.title, newUrl);
            } else if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: errorMsg,
                    confirmButtonColor: '#5c1e28'
                });
                const remainingParams = Array.from(urlParams.entries())
                    .filter(([key]) => key !== 'success' && key !== 'error')
                    .map(([key, val]) => `${key}=${encodeURIComponent(val)}`)
                    .join('&');
                const newUrl = window.location.pathname + (remainingParams ? '?' + remainingParams : '');
                window.history.replaceState({}, document.title, newUrl);
            }
        });
    </script>
</body>
</html>
