            // Direct update for a single variant
            async function updateVariantDirect(variantId) {
                const colorInput = document.getElementById(`colorInput-${variantId}`);
                const qtyInput = document.getElementById(`qtyInput-${variantId}`);
                const regPriceInput = document.getElementById(`regPriceInput-${variantId}`);
                const salePriceInput = document.getElementById(`salePriceInput-${variantId}`);
                const hexInput = document.getElementById(`hexInput-${variantId}`);

                const color = colorInput.value.trim();
                const quantity = parseInt(qtyInput.value);
                const regularPrice = parseFloat(regPriceInput.value);
                const salePrice = parseFloat(salePriceInput.value);
                const hexCode = hexInput.value.trim();

                // Write trimmed values back so submitted data is clean
                colorInput.value = color;
                hexInput.value   = hexCode;

                let hasError = false;

                // Helper to show/clear inline errors
                function vErr(input, errId, show, msg = '') {
                    input.classList.toggle('input-error', show);
                    let span = document.getElementById(errId);
                    if (!span && show) {
                        span = document.createElement('span');
                        span.id = errId;
                        span.className = 'field-error visible';
                        span.textContent = msg;
                        input.parentNode.insertBefore(span, input.nextSibling);
                    } else if (span) {
                        span.classList.toggle('visible', show);
                        if (show && msg) span.textContent = msg;
                    }
                }

                const colorErrId = `updateColorErr-${variantId}`;
                const qtyErrId = `updateQtyErr-${variantId}`;
                const regErrId = `updateRegErr-${variantId}`;
                const saleErrId = `updateSaleErr-${variantId}`;
                const hexErrId = `updateHexErr-${variantId}`;

                // Validate each field
                if (!color) {
                    vErr(colorInput, colorErrId, true, 'Color name is required.');
                    hasError = true;
                } else {
                    vErr(colorInput, colorErrId, false);
                }

                if (isNaN(quantity) || qtyInput.value.trim() === '') {
                    vErr(qtyInput, qtyErrId, true, 'Quantity is required.');
                    hasError = true;
                } else if (quantity < 0) {
                    vErr(qtyInput, qtyErrId, true, 'Quantity cannot be negative.');
                    hasError = true;
                } else {
                    vErr(qtyInput, qtyErrId, false);
                }

                if (isNaN(regularPrice) || regPriceInput.value.trim() === '') {
                    vErr(regPriceInput, regErrId, true, 'Regular price is required.');
                    hasError = true;
                } else if (regularPrice < 0) {
                    vErr(regPriceInput, regErrId, true, 'Regular price cannot be negative.');
                    hasError = true;
                } else {
                    vErr(regPriceInput, regErrId, false);
                }

                if (isNaN(salePrice) || salePriceInput.value.trim() === '') {
                    vErr(salePriceInput, saleErrId, true, 'Sale price is required.');
                    hasError = true;
                } else if (salePrice < 0) {
                    vErr(salePriceInput, saleErrId, true, 'Sale price cannot be negative.');
                    hasError = true;
                } else if (salePrice > regularPrice) {
                    vErr(salePriceInput, saleErrId, true, 'Sale price cannot exceed regular price.');
                    hasError = true;
                } else {
                    vErr(salePriceInput, saleErrId, false);
                }

                if (!hexCode) {
                    vErr(hexInput, hexErrId, true, 'Hex code is required.');
                    hasError = true;
                } else if (!isValidHex(hexCode)) {
                    vErr(hexInput, hexErrId, true, 'Invalid hex code (e.g. #FF5733).');
                    hasError = true;
                } else {
                    vErr(hexInput, hexErrId, false);
                }

                if (hasError) return;

                try {
                    const response = await fetch(`/admin/variants/update/${variantId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ color, hexCode, quantity, regularPrice, salePrice })
                    });

                    const data = await response.json();

                    if (data.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Updated!',
                            text: 'Variant updated successfully!',
                            confirmButtonColor: '#5c1e28',
                            timer: 2000,
                            showConfirmButton: false
                        });
                        // Redirect to products page after success
                        window.location.href = '/admin/products';
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Error updating variant',
                            confirmButtonColor: '#5c1e28'
                        });
                    }
                } catch (error) {
                    console.error('Error:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Error updating variant',
                        confirmButtonColor: '#5c1e28'
                    });
                }
            }



            function syncHex(variantId, hexValue) {
                document.getElementById(`hexInput-${variantId}`).value = hexValue.toUpperCase();
                updateShadePreview(variantId, hexValue);
            }

            function syncPicker(variantId, rawValue) {
                const hex = rawValue.startsWith('#') ? rawValue : '#' + rawValue;
                if (isValidHex(hex)) {
                    document.getElementById(`colorPicker-${variantId}`).value = hex;
                    updateShadePreview(variantId, hex);
                }
            }

            function updateShadePreview(variantId, hex) {
                const preview = document.getElementById(`shadePreview-${variantId}`);
                if (preview && isValidHex(hex)) {
                    preview.style.backgroundColor = hex;
                    preview.style.borderColor = hex;
                }
            }

            function isValidHex(hex) {
                return /^#([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$/.test(hex);
            }

            // --- New variant functions ---
            function syncNewHex(hexValue) {
                document.getElementById('newHexInput').value = hexValue.toUpperCase();
                const preview = document.getElementById('newShadePreview');
                preview.style.backgroundColor = hexValue;
                preview.style.borderColor = hexValue;
            }

            function syncNewPicker(rawValue) {
                const hex = rawValue.startsWith('#') ? rawValue : '#' + rawValue;
                if (isValidHex(hex)) {
                    document.getElementById('newColorPicker').value = hex;
                    const preview = document.getElementById('newShadePreview');
                    preview.style.backgroundColor = hex;
                    preview.style.borderColor = hex;
                }
            }

            let newVariantFiles = [];

            function handleNewVariantImages(files) {
                if (files.length === 0) return;
                const file = files[0];
                
                // Clear input value
                document.getElementById('newVariantImages').value = '';
                
                cropImageHelper(file, function(croppedFile) {
                    if (!croppedFile) return;
                    newVariantFiles.push(croppedFile);
                    renderNewImagesPreview();
                });
            }

            function renderNewImagesPreview() {
                const previewContainer = document.getElementById('newImagesPreview');
                previewContainer.innerHTML = '';

                newVariantFiles.forEach((file, index) => {
                    const reader = new FileReader();
                    const box = document.createElement('div');
                    box.className = 'image-preview-box';
                    previewContainer.appendChild(box);

                    reader.onload = function (e) {
                        box.innerHTML = `
                        <img src="${e.target.result}" alt="Preview">
                        <button type="button" class="remove-image-btn" onclick="removeNewImage(${index}); event.stopPropagation();">×</button>
                    `;
                    };
                    reader.readAsDataURL(file);
                });

                const clickBox = document.createElement('div');
                clickBox.className = 'image-preview-box';
                clickBox.onclick = () => document.getElementById('newVariantImages').click();
                clickBox.innerHTML = `
                <div class="image-preview-placeholder">
                    <i class="fas fa-camera"></i>
                    <p>Click to upload</p>
                </div>
            `;
                previewContainer.appendChild(clickBox);
            }

            function removeNewImage(index) {
                newVariantFiles.splice(index, 1);
                renderNewImagesPreview();
            }

