    <div id="cropperModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.85); z-index: 9999; align-items: center; justify-content: center; flex-direction: column;">
        <div style="background: white; border-radius: 12px; padding: 25px; width: 90vw; max-width: 600px; display: flex; flex-direction: column; gap: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
            <h3 style="font-family: 'Playfair Display', serif; color: #5c1e28; margin: 0;">Crop Image</h3>
            <div style="max-height: 400px; width: 100%; display: flex; justify-content: center; align-items: center; overflow: hidden; background: #f0f0f0; border-radius: 8px;">
                <img id="cropperImage" style="max-width: 100%; max-height: 400px; display: block;">
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 15px;">
                <button id="cropperCancelBtn" type="button" style="padding: 10px 24px; border: 1.5px solid #ccc; background: transparent; border-radius: 30px; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.3s;">Cancel</button>
                <button id="cropperCropBtn" type="button" style="padding: 10px 24px; border: none; background: #5c1e28; color: white; border-radius: 30px; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 12px rgba(92, 30, 40, 0.355);">Crop & Save</button>
            </div>
        </div>
    </div>
</body>
</html>