<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product - Veloura Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f5f5;
            display: flex;
            min-height: 100vh;
        }



        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #5c1e28;
            margin-bottom: 40px;
            font-weight: 400;
        }

        .form-card {
            background: white;
            border-radius: 8px;
            padding: 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            color: #5c1e28;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 25px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #666;
            margin-bottom: 10px;
        }

        .form-input,
        .form-select,
        .form-textarea {
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 5px;
            background: white;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #333;
            outline: none;
            transition: border-color 0.3s;
        }

        .form-input:focus,
        .form-select:focus,
        .form-textarea:focus {
            border-color: #5c1e28;
        }

        .form-input.input-error,
        .form-select.input-error,
        .form-textarea.input-error {
            border-color: #dc3545;
        }

        .field-error {
            color: #dc3545;
            font-size: 11px;
            margin-top: 5px;
            display: none;
        }

        .field-error.visible {
            display: block;
        }

        .form-textarea {
            resize: none;
            min-height: 100px;
        }

        /* Variant Section */
        .variant-card {
            background: #fafafa;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 30px;
            margin-bottom: 20px;
            position: relative;
        }

        .variant-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .variant-number {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            color: #5c1e28;
            font-weight: 600;
        }

        .btn-delete-variant {
            padding: 8px 16px;
            background-color: #dc3545;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s;
        }

        .btn-delete-variant:hover {
            background-color: #c82333;
        }

        .image-preview-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .image-preview-box {
            position: relative;
            width: 100%;
            padding-bottom: 100%;
            border: 2px dashed #ddd;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s;
            background: white;
        }

        .image-preview-box:hover {
            border-color: #5c1e28;
        }

        .image-preview-box img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .image-preview-placeholder {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: #999;
        }

        .image-preview-placeholder i {
            font-size: 24px;
            margin-bottom: 8px;
        }

        .image-preview-placeholder p {
            font-size: 11px;
        }

        .remove-image-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 24px;
            height: 24px;
            background-color: #c9302c;
            color: white;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            z-index: 10;
        }

        .remove-image-btn:hover {
            background-color: #a52420;
        }

        .file-input {
            display: none;
        }

        .btn-add-variant {
            padding: 14px 30px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-add-variant:hover {
            background-color: #218838;
        }

        .form-footer {
            margin-top: 40px;
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn-save {
            padding: 14px 50px;
            background-color: #5c1e28;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-save:hover {
            background-color: #4a1620;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(92, 30, 40, 0.3);
        }

        .btn-cancel {
            padding: 14px 50px;
            background-color: #6c757d;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
        }

        .btn-cancel:hover {
            background-color: #5a6268;
        }

        .error-message {
            padding: 15px;
            background-color: #f8d7da;
            color: #721c24;
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .success-message {
            padding: 15px;
            background-color: #d4edda;
            color: #155724;
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .upload-note {
            font-size: 12px;
            color: #999;
            margin-bottom: 10px;
        }

        .btn-add-image {
            padding: 8px 16px;
            background-color: #5c1e28;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .btn-add-image:hover {
            background-color: #4a1620;
        }

        .btn-edit-variant {
            padding: 8px 16px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s;
        }

        .btn-edit-variant:hover {
            background-color: #0056b3;
        }

        /* Shade swatch styles */
        .shade-row {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .shade-preview {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid #ddd;
            flex-shrink: 0;
            background: #f0f0f0;
            transition: background-color 0.2s;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
        }

        .hex-input-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 1;
        }

        .hex-input-wrap input[type="color"] {
            width: 38px;
            height: 38px;
            padding: 2px;
            border: 1px solid #ddd;
            border-radius: 5px;
            cursor: pointer;
            background: white;
        }

        .hex-input-wrap .form-input {
            font-family: 'Inter', monospace;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
    </style>
</head>

<body>
    <%- include('../partials/admin/sidebar', { selectedTab: 'products' }) %>


        <!-- Main Content -->
        <main class="main-content">
            <h1 class="page-title">Edit Product</h1>

            <% if (errorMessage) { %>
                <div class="error-message">
                    <%= errorMessage %>
                </div>
                <% } %>

                    <form action="/admin/products/edit/<%= product._id %>" method="POST" id="productForm">

                        <!-- Product Common Details -->
                        <div class="form-card">
                            <h3 class="section-title">Product Details</h3>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">PRODUCT NAME *</label>
                                    <input type="text" id="editProductName" name="productName" class="form-input"
                                        value="<%= product.productName %>">
                                    <span class="field-error" id="editProductNameError">Product name is required.</span>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">CATEGORY *</label>
                                    <select id="editCategoryId" name="categoryId" class="form-select">
                                        <option value="">Select Category</option>
                                        <% if (categories && categories.length> 0) { %>
                                            <% categories.forEach(category=> { %>
                                                <option value="<%= category._id %>"
                                                    <%=product.categoryId._id.toString()===category._id.toString()
                                                    ? 'selected' : '' %>>
                                                    <%= category.name %>
                                                </option>
                                                <% }) %>
                                                    <% } %>
                                    </select>
                                    <span class="field-error" id="editCategoryIdError">Please select a category.</span>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">BRAND *</label>
                                    <input type="text" id="editBrand" name="brand" class="form-input" value="<%= product.brand %>">
                                    <span class="field-error" id="editBrandError">Brand is required.</span>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">STATUS</label>
                                    <select name="status" class="form-select">
                                        <option value="ACTIVE" <%=product.status==='ACTIVE' ? 'selected' : '' %>>Active
                                        </option>
                                        <option value="INACTIVE" <%=product.status==='INACTIVE' ? 'selected' : '' %>
                                            >Inactive</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group full-width">
                                <label class="form-label">DESCRIPTION *</label>
                                <textarea id="editDescription" name="description" class="form-textarea"><%= product.description %></textarea>
                                <span class="field-error" id="editDescriptionError">Description is required.</span>
                            </div>

                        </div>

                        </div>

                        <!-- Existing Variants Section -->
                        <div class="form-card">
                            <h3 class="section-title">Product Variants</h3>
                            <p class="upload-note">Manage existing variants and their images. Add images one by one.</p>

                            <% if (variants && variants.length> 0) { %>
                                <% variants.forEach((variant, index)=> { %>
                                    <div class="variant-card" data-variant-id="<%= variant._id %>">
                                        <div class="variant-header">
                                            <span class="variant-number">Variant <%= index + 1 %> - <%= variant.color %>
                                                        </span>
                                            <div style="display: flex; gap: 10px;">
                                                <button type="button" class="btn-edit-variant"
                                                    style="background-color: #28a745;"
                                                    onclick="updateVariantDirect('<%= variant._id %>')">
                                                    UPDATE
                                                </button>
                                                <button type="button" class="btn-delete-variant"
                                                    onclick="deleteVariant('<%= variant._id %>')">
                                                    Delete Variant
                                                </button>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <input type="hidden" name="variants[<%= variant._id %>][_id]"
                                                value="<%= variant._id %>">
                                            <div class="form-group">
                                                <label class="form-label">COLOR NAME *</label>
                                                <input type="text" name="variants[<%= variant._id %>][color]"
                                                    id="colorInput-<%= variant._id %>" value="<%= variant.color %>"
                                                    class="form-input">
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label">QUANTITY *</label>
                                                <input type="number" name="variants[<%= variant._id %>][quantity]"
                                                    id="qtyInput-<%= variant._id %>" value="<%= variant.quantity %>"
                                                    class="form-input" min="0">
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group" style="grid-column: 1 / -1;">
                                                <label class="form-label">SHADE COLOUR (HEX CODE) *</label>
                                                <div class="shade-row">
                                                    <div class="shade-preview" id="shadePreview-<%= variant._id %>"
                                                        style="background-color: <%= variant.hexCode && variant.hexCode.trim() ? variant.hexCode : '#ffffff' %>; border-color: <%= variant.hexCode && variant.hexCode.trim() ? variant.hexCode : '#ddd' %>;">
                                                    </div>
                                                    <div class="hex-input-wrap">
                                                        <input type="color" id="colorPicker-<%= variant._id %>"
                                                            value="<%= variant.hexCode && variant.hexCode.trim() ? variant.hexCode : '#ffffff' %>"
                                                            oninput="syncHex('<%= variant._id %>', this.value)"
                                                            onchange="syncHex('<%= variant._id %>', this.value)">
                                                        <input type="text" name="variants[<%= variant._id %>][hexCode]"
                                                            id="hexInput-<%= variant._id %>"
                                                            value="<%= variant.hexCode || '' %>" class="form-input"
                                                            placeholder="#FF5733" maxlength="7"
                                                            oninput="syncPicker('<%= variant._id %>', this.value)">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">REGULAR PRICE (₹) *</label>
                                                <input type="number" name="variants[<%= variant._id %>][regularPrice]"
                                                    id="regPriceInput-<%= variant._id %>"
                                                    value="<%= variant.regularPrice %>" class="form-input" min="0"
                                                    step="0.01">
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label">SALE PRICE (₹) *</label>
                                                <input type="number" name="variants[<%= variant._id %>][salePrice]"
                                                    id="salePriceInput-<%= variant._id %>"
                                                    value="<%= variant.salePrice %>" class="form-input" min="0"
                                                    step="0.01">
                                            </div>
                                        </div>

                                        <div class="form-group full-width">
                                            <label class="form-label">VARIANT IMAGES (<%= variant.images.length %>
                                                    images)</label>
                                            <input type="file" id="variantImageInput-<%= variant._id %>"
                                                class="file-input" accept="image/*"
                                                onchange="addImageToVariant('<%= variant._id %>', this.files[0])">

                                            <div class="image-preview-container" id="imagePreview-<%= variant._id %>">
                                                <% variant.images.forEach((image, imgIndex)=> { %>
                                                    <div class="image-preview-box" data-image-index="<%= imgIndex %>">
                                                        <img src="<%= image %>" alt="Variant Image">
                                                        <button type="button" class="remove-image-btn"
                                                            onclick="removeImageFromVariant('<%= variant._id %>', '<%= image %>', this); event.stopPropagation();">
                                                            ×
                                                        </button>
                                                    </div>
                                                    <% }) %>
                                            </div>

                                            <button type="button" class="btn-add-image"
                                                onclick="document.getElementById('variantImageInput-<%= variant._id %>').click()">
                                                <i class="fas fa-plus"></i> Add Image
                                            </button>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <p style="color: #999; text-align: center; padding: 20px;">No variants found
                                                for this product.</p>
                                            <% } %>

                                                <!-- Add Variant Section -->
                                                <div class="variant-card"
                                                    style="border: 2px dashed #28a745; background-color: #f8fff9; margin-top: 40px;"
                                                    id="addVariantSection">
                                                    <div class="variant-header">
                                                        <span class="variant-number" style="color: #28a745;"><i
                                                                class="fas fa-plus-circle"></i> Add New Variant</span>
                                                    </div>

                                                    <div class="form-row">
                                                        <div class="form-group">
                                                            <label class="form-label">COLOR NAME *</label>
                                                            <input type="text" id="newVariantColor" class="form-input"
                                                                placeholder="e.g., Ruby Red, Rose Pink...">
                                                        </div>

                                                        <div class="form-group">
                                                            <label class="form-label">QUANTITY *</label>
                                                            <input type="number" id="newVariantQuantity"
                                                                class="form-input" placeholder="0" min="0">
                                                        </div>
                                                    </div>

                                                    <div class="form-row">
                                                        <div class="form-group" style="grid-column: 1 / -1;">
                                                            <label class="form-label">SHADE COLOUR (HEX CODE) *</label>
                                                            <div class="shade-row">
                                                                <div class="shade-preview" id="newShadePreview"
                                                                    style="background-color: #5c1e28; border-color: #5c1e28;">
                                                                </div>
                                                                <div class="hex-input-wrap">
                                                                    <input type="color" id="newColorPicker"
                                                                        value="#5c1e28" oninput="syncNewHex(this.value)"
                                                                        onchange="syncNewHex(this.value)">
                                                                    <input type="text" id="newHexInput"
                                                                        class="form-input" placeholder="#FF5733"
                                                                        value="#5C1E28" maxlength="7"
                                                                        oninput="syncNewPicker(this.value)">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="form-row">
                                                        <div class="form-group">
                                                            <label class="form-label">REGULAR PRICE (₹) *</label>
                                                            <input type="number" id="newVariantRegPrice"
                                                                class="form-input" placeholder="0.00" min="0"
                                                                step="0.01">
                                                        </div>

                                                        <div class="form-group">
                                                            <label class="form-label">SALE PRICE (₹) *</label>
                                                            <input type="number" id="newVariantSalePrice"
                                                                class="form-input" placeholder="0.00" min="0"
                                                                step="0.01">
                                                        </div>
                                                    </div>

                                                    <div class="form-group full-width" style="margin-bottom: 20px;">
                                                        <label class="form-label">VARIANT IMAGES * (Min 3
                                                            images)</label>
                                                        <input type="file" id="newVariantImages" class="file-input"
                                                            accept="image/*" multiple
                                                            onchange="handleNewVariantImages(this.files)">

                                                        <div class="image-preview-container" id="newImagesPreview">
                                                            <div class="image-preview-box"
                                                                onclick="document.getElementById('newVariantImages').click()">
                                                                <div class="image-preview-placeholder">
                                                                    <i class="fas fa-camera"></i>
                                                                    <p>Click to upload</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <button type="button" class="btn-add-variant"
                                                        onclick="submitNewVariant()">
                                                        <i class="fas fa-plus"></i> Save Variant to Product
                                                    </button>
                                                </div>
                        </div>
        </main>

        <script>
        // Form submission confirmation and JS validation with SweetAlert
        document.getElementById('productForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = this;
            let hasError = false;

            // Helper: show/clear inline errors
            function showErr(id, errId, show) {
                const el = document.getElementById(id);
                const err = document.getElementById(errId);
                if (!el || !err) return;
                el.classList.toggle('input-error', show);
                err.classList.toggle('visible', show);
            }

            // ── Product-level fields ─────────────────────────────────
            // Trim and write back to inputs before validation
            const productNameInput = document.getElementById('editProductName');
            const brandInput       = document.getElementById('editBrand');
            const descriptionInput = document.getElementById('editDescription');

            productNameInput.value = productNameInput.value.trim();
            brandInput.value       = brandInput.value.trim();
            descriptionInput.value = descriptionInput.value.trim();

            const productName = productNameInput.value;
            const categoryId  = document.getElementById('editCategoryId').value;
            const brand       = brandInput.value;
            const description = descriptionInput.value;

            showErr('editProductName', 'editProductNameError', !productName);
            showErr('editCategoryId',  'editCategoryIdError',  !categoryId);
            showErr('editBrand',       'editBrandError',       !brand);
            showErr('editDescription', 'editDescriptionError', !description);

            if (!productName || !categoryId || !brand || !description) hasError = true;

            // ── Existing variant fields ───────────────────────────────
            const variantCards = form.querySelectorAll('.variant-card[data-variant-id]');
            for (let card of variantCards) {
                const variantId = card.getAttribute('data-variant-id');

                const colorInput     = document.getElementById(`colorInput-${variantId}`);
                const qtyInput       = document.getElementById(`qtyInput-${variantId}`);
                const regPriceInput  = document.getElementById(`regPriceInput-${variantId}`);
                const salePriceInput = document.getElementById(`salePriceInput-${variantId}`);
                const hexInput       = document.getElementById(`hexInput-${variantId}`);

                const color        = colorInput.value.trim();
                const quantity     = qtyInput.value.trim();
                const regularPrice = regPriceInput.value.trim();
                const salePrice    = salePriceInput.value.trim();
                const hexCode      = hexInput.value.trim();

                // Write trimmed values back so submitted data is clean
                colorInput.value = color;
                hexInput.value   = hexCode;

                // Inline error helper for variant fields
                function vErr(input, errId, show) {
                    input.classList.toggle('input-error', show);
                    let span = document.getElementById(errId);
                    if (!span) {
                        if (show) {
                            span = document.createElement('span');
                            span.id = errId;
                            span.className = 'field-error visible';
                            input.parentNode.insertBefore(span, input.nextSibling);
                        }
                    } else {
                        span.classList.toggle('visible', show);
                    }
                }

                const colorErrId    = `colorErr-${variantId}`;
                const qtyErrId      = `qtyErr-${variantId}`;
                const regErrId      = `regErr-${variantId}`;
                const saleErrId     = `saleErr-${variantId}`;
                const hexErrId      = `hexErr-${variantId}`;

                vErr(colorInput,     colorErrId, !color);
                vErr(qtyInput,       qtyErrId,   quantity === '');
                vErr(regPriceInput,  regErrId,   regularPrice === '');
                vErr(salePriceInput, saleErrId,  salePrice === '');
                vErr(hexInput,       hexErrId,   !hexCode);

                if (!color) { getOrCreateSpan(colorErrId).textContent = 'Color name is required.'; }
                if (quantity === '') { getOrCreateSpan(qtyErrId).textContent = 'Quantity is required.'; }
                if (regularPrice === '') { getOrCreateSpan(regErrId).textContent = 'Regular price is required.'; }
                if (salePrice === '') { getOrCreateSpan(saleErrId).textContent = 'Sale price is required.'; }
                if (!hexCode) { getOrCreateSpan(hexErrId).textContent = 'Hex code is required.'; }

                if (!color || quantity === '' || regularPrice === '' || salePrice === '' || !hexCode) {
                    hasError = true; continue;
                }

                const qty  = parseFloat(quantity);
                const regP = parseFloat(regularPrice);
                const salP = parseFloat(salePrice);

                if (qty < 0) {
                    vErr(qtyInput, qtyErrId, true);
                    getOrCreateSpan(qtyErrId).textContent = 'Quantity cannot be negative.';
                    hasError = true;
                }
                if (regP < 0) {
                    vErr(regPriceInput, regErrId, true);
                    getOrCreateSpan(regErrId).textContent = 'Regular price cannot be negative.';
                    hasError = true;
                }
                if (salP < 0) {
                    vErr(salePriceInput, saleErrId, true);
                    getOrCreateSpan(saleErrId).textContent = 'Sale price cannot be negative.';
                    hasError = true;
                }
                if (salP > regP) {
                    vErr(salePriceInput, saleErrId, true);
                    getOrCreateSpan(saleErrId).textContent = 'Sale price cannot exceed regular price.';
                    hasError = true;
                }
                if (!isValidHex(hexCode)) {
                    vErr(hexInput, hexErrId, true);
                    getOrCreateSpan(hexErrId).textContent = 'Invalid hex code (e.g. #FF5733).';
                    hasError = true;
                }
            }

            if (hasError) return;

            const result = await Swal.fire({
                title: 'Save Changes?',
                text: 'Are you sure you want to update this product?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#999',
                confirmButtonText: 'Yes, Save',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                form.submit();
            }
        });

