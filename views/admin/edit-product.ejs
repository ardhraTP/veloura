                // Add real-time error clearing for new variant fields
                ['newVariantColor', 'newVariantQuantity', 'newVariantRegPrice', 'newVariantSalePrice', 'newHexInput'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) {
                        el.addEventListener('input', function() {
                            this.classList.remove('input-error');
                            const errSpan = this.nextElementSibling;
                            if (errSpan && errSpan.classList.contains('field-error')) {
                                errSpan.classList.remove('visible');
                            }
