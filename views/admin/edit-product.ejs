        let currentCropper = null;

        function cropImageHelper(file, callback) {
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const modal = document.getElementById('cropperModal');
                const img = document.getElementById('cropperImage');
                img.src = e.target.result;
                modal.style.display = 'flex';

                if (currentCropper) {
                    currentCropper.destroy();
                }

                currentCropper = new Cropper(img, {
                    aspectRatio: 1, // 1:1 square crop
                    viewMode: 1,
                    autoCropArea: 1,
                    responsive: true,
                    restore: false,
                    guides: true,
                    center: true,
                    highlight: false,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: false
                });

                const cropBtn = document.getElementById('cropperCropBtn');
                const cancelBtn = document.getElementById('cropperCancelBtn');

                const newCropBtn = cropBtn.cloneNode(true);
                const newCancelBtn = cancelBtn.cloneNode(true);

                cropBtn.parentNode.replaceChild(newCropBtn, cropBtn);
                cancelBtn.parentNode.replaceChild(newCancelBtn, cancelBtn);

                newCropBtn.addEventListener('click', function() {
                    const canvas = currentCropper.getCroppedCanvas({
                        width: 800,
                        height: 800
                    });

                    canvas.toBlob(function(blob) {
                        const croppedFile = new File([blob], file.name, {
                            type: 'image/jpeg',
                            lastModified: Date.now()
                        });

                        modal.style.display = 'none';
                        currentCropper.destroy();
                        currentCropper = null;

                        callback(croppedFile);
                    }, 'image/jpeg', 0.9);
                });

                newCancelBtn.addEventListener('click', function() {
                    modal.style.display = 'none';
                    currentCropper.destroy();
                    currentCropper = null;
                    callback(null);
                });
            };
            reader.readAsDataURL(file);
        }

