            // Show success/error notifications from URL parameters and clear them
            document.addEventListener('DOMContentLoaded', function() {
                const urlParams = new URLSearchParams(window.location.search);
                const successMsg = urlParams.get('success');
                const errorMsg = urlParams.get('error');

                if (successMsg) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: successMsg,
                        confirmButtonColor: '#5c1e28',
                        timer: 3000,
                        showConfirmButton: false
                    });
                    const remainingParams = Array.from(urlParams.entries())
                        .filter(([key]) => key !== 'success' && key !== 'error')
                        .map(([key, val]) => `${key}=${encodeURIComponent(val)}`)
                        .join('&');
                    const newUrl = window.location.pathname + (remainingParams ? '?' + remainingParams : '');
                    window.history.replaceState({}, document.title, newUrl);
                } else if (errorMsg) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: errorMsg,
                        confirmButtonColor: '#5c1e28'
                    });
                    const remainingParams = Array.from(urlParams.entries())
                        .filter(([key]) => key !== 'success' && key !== 'error')
                        .map(([key, val]) => `${key}=${encodeURIComponent(val)}`)
                        .join('&');
                    const newUrl = window.location.pathname + (remainingParams ? '?' + remainingParams : '');
                    window.history.replaceState({}, document.title, newUrl);
                }

                // Add real-time error clearing for existing variant fields
                document.querySelectorAll('.variant-card[data-variant-id]').forEach(card => {
                    const variantId = card.getAttribute('data-variant-id');
                    ['colorInput', 'qtyInput', 'regPriceInput', 'salePriceInput', 'hexInput'].forEach(prefix => {
                        const el = document.getElementById(`${prefix}-${variantId}`);
                        if (el) {
                            el.addEventListener('input', function() {
                                this.classList.remove('input-error');
                                const errSpan = this.nextElementSibling;
                                if (errSpan && errSpan.classList.contains('field-error')) {
                                    errSpan.classList.remove('visible');
