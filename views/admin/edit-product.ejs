                    }
                });

                // Clear image error when files are added
                const newVariantImagesInput = document.getElementById('newVariantImages');
                if (newVariantImagesInput) {
                    newVariantImagesInput.addEventListener('change', function() {
                        const imgErrSpan = document.getElementById('newImgErr');
                        if (imgErrSpan) imgErrSpan.classList.remove('visible');
                    });
                }
            });
