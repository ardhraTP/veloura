<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - Veloura Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f2f0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 260px;
            background-color: #fcfbf9;
            border-right: 1px solid #ebe7e5;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .sidebar-header {
            padding: 30px 40px;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 600;
            color: #5c1e28;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .sidebar-menu {
            overflow-y: auto;
            list-style: none;
            padding: 10px 0;
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 15px 40px;
            color: #2d2a29;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar-menu a i {
            width: 24px;
            font-size: 16px;
            color: #888380;
            margin-right: 15px;
        }

        .sidebar-menu a:hover {
            background-color: #f7f1f1;
        }

        .sidebar-menu a.active {
            background-color: #f7eded;
            color: #5c1e28;
            font-weight: 600;
        }

        .sidebar-menu a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background-color: #5c1e28;
        }

        .sidebar-menu a.active i {
            color: #5c1e28;
        }

        .logout-btn {
            display: block;
            width: 100%;
            padding: 14px !important;
            background-color: #c9302c;
            color: #ffffff !important;
            text-align: center;
            border-radius: 6px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.2s;
        }

        .logout-btn:hover {
            background-color: #ac2925;
            color: #ffffff !important;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 40px;
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .breadcrumb {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .breadcrumb span {
            color: #5c1e28;
            font-weight: 600;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: #6b6b6b;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .user-icon {
            width: 24px;
            height: 24px;
            border: 2px solid #5c1e28;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #5c1e28;
        }

        /* Page Title */
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #5c1e28;
            margin-bottom: 30px;
            font-weight: 400;
        }

        /* Toolbar */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .toolbar-left {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .filter-btn, .search-box {
            padding: 10px 20px;
            border: 1px solid #ddd;
            border-radius: 5px;
            background: white;
            font-size: 13px;
            cursor: pointer;
        }

        .search-box {
            width: 250px;
        }

        .btn-add-product {
            padding: 12px 30px;
            background-color: #5c1e28;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s;
        }

        .btn-add-product:hover {
            background-color: #4a1620;
            transform: translateY(-2px);
        }

        /* Table Card */
        .table-card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background-color: #5c1e28;
        }

        th {
            padding: 18px 30px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: white;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        td {
            padding: 20px 30px;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }

        tbody tr:hover {
            background-color: #fafafa;
        }

        .product-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .product-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 5px;
        }

        .product-details h4 {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 16px;
            color: #333;
            margin-bottom: 4px;
        }

        .product-details p {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .category-badge {
            padding: 6px 16px;
            background-color: #ffe6e6;
            color: #5c1e28;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }

        .action-btns {
            display: flex;
            gap: 10px;
        }

        .btn-edit, .btn-block {
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-edit {
            background-color: transparent;
            color: #666;
            text-decoration: underline;
        }

        .btn-edit:hover {
            color: #5c1e28;
        }

        .btn-block {
            background-color: #f0f0f0;
            color: #666;
        }

        .btn-block:hover {
            background-color: #e0e0e0;
        }

        .btn-delete {
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            font-size: 12px;
            cursor: pointer;
            background-color: #f8d7da;
            color: #721c24;
            transition: all 0.3s;
        }

        .btn-delete:hover {
            background-color: #f5c6cb;
        }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin: 30px 0;
        }

        .page-btn {
            width: 35px;
            height: 35px;
            border: 1px solid #ddd;
            background: white;
            border-radius: 5px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
        }

        .page-btn.active {
            background-color: #5c1e28;
            color: white;
            border-color: #5c1e28;
        }

        .page-btn:hover:not(.active) {
            background-color: #f5f5f5;
        }

        .page-btn {
            text-decoration: none;
            color: #333;
            display: inline-block;
        }

        .page-btn.active {
            color: white;
        }

        /* Product Cards */
        .product-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 40px;
        }

        .product-card {
            padding: 30px;
            border-radius: 8px;
            color: white;
        }

        .product-card.card-1 {
            background: linear-gradient(135deg, #5c1e28 0%, #8b2635 100%);
        }

        .product-card.card-2 {
            background: linear-gradient(135deg, #d4d4d4 0%, #e8e8e8 100%);
            color: #333;
        }

        .product-card.card-3 {
            background: linear-gradient(135deg, #d4d4d4 0%, #e8e8e8 100%);
            color: #333;
        }

        .card-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            opacity: 0.9;
            margin-bottom: 10px;
        }

        .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .card-subtitle {
            font-size: 13px;
            opacity: 0.8;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            color: #999;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/admin/dashboard" class="logo">Veloura</a>
        </div>
        
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard"><i class="fas fa-th-large"></i> Dashboard</a></li>
            <li><a href="/admin/products" class="active"><i class="fas fa-box"></i> Products</a></li>
            <li><a href="#"><i class="fas fa-clipboard-list"></i> Order List</a></li>
            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
            <li><a href="#"><i class="fas fa-chart-line"></i> Sales Report</a></li>
            <li><a href="#"><i class="fas fa-ticket-alt"></i> Coupons</a></li>
            <li><a href="/admin/categories"><i class="fas fa-list"></i> Category</a></li>
            <li><a href="#"><i class="fas fa-star"></i> Reviews</a></li>
            <li style="padding: 20px 40px; margin-top: 10px;">
                <a href="/admin/logout" class="logout-btn">Log Out</a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <div class="breadcrumb">
                INVENTORY › <span>CATALOG</span>
            </div>
            <div class="user-info">
                ARDRA
                <div class="user-icon">👤</div>
            </div>
        </div>

        <!-- Page Title -->
        <h1 class="page-title">Products</h1>

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="toolbar-left">
                <form action="/admin/products" method="GET" style="display: flex; gap: 15px;">
                    <input type="text" 
                           name="search" 
                           value="<%= search %>" 
                           class="search-box" 
                           placeholder="SEARCH">
                    <button type="submit" class="filter-btn">SEARCH</button>
                    <% if (search) { %>
                        <a href="/admin/products" class="filter-btn" style="text-decoration: none;">CLEAR</a>
                    <% } %>
                </form>
            </div>
            <a href="/admin/products/add" class="btn-add-product">+ ADD NEW PRODUCT</a>
        </div>

        <!-- Products Table -->
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>PRODUCT</th>
                        <th>CATEGORY</th>
                        <th>PRICE</th>
                        <th>PIECES</th>
                        <th>ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <tr id="product-row-<%= product._id %>">
                                <td>
                                    <div class="product-info">
                                        <% if (product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0) { %>
                                            <img src="<%= product.variants[0].images[0] %>" alt="<%= product.productName %>" class="product-image">
                                        <% } else { %>
                                            <img src="https://via.placeholder.com/60" alt="No image" class="product-image">
                                        <% } %>
                                        <div class="product-details">
                                            <h4><%= product.productName %></h4>
                                            <p><%= product.variants ? product.variants.length : 0 %> Variants</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="category-badge"><%= product.categoryId ? product.categoryId.name : 'N/A' %></span>
                                </td>
                                <td>
                                    <% if (product.variants && product.variants.length > 0) { %>
                                        ₹<%= Math.min(...product.variants.map(v => v.salePrice)).toFixed(2) %>
                                        <% if (product.variants.length > 1) { %>
                                            - ₹<%= Math.max(...product.variants.map(v => v.salePrice)).toFixed(2) %>
                                        <% } %>
                                    <% } else { %>
                                        N/A
                                    <% } %>
                                </td>
                                <td>
                                    <% if (product.variants && product.variants.length > 0) { %>
                                        <%= product.variants.reduce((sum, v) => sum + v.quantity, 0) %>
                                    <% } else { %>
                                        0
                                    <% } %>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <a href="/admin/products/edit/<%= product._id %>" class="btn-edit">EDIT</a>
                                        <button class="btn-block" onclick="toggleStatus('<%= product._id %>', '<%= product.status %>')">
                                            <%= product.status === 'ACTIVE' ? 'DEACTIVATE' : 'ACTIVATE' %>
                                        </button>
                                        <button class="btn-delete" onclick="deleteProduct('<%= product._id %>')">
                                            DELETE
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <p>No products found. Add your first product.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>" class="page-btn">«</a>
                <% } %>
                
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" 
                       class="page-btn <%= currentPage === i ? 'active' : '' %>">
                        <%= i %>
                    </a>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>" class="page-btn">»</a>
                <% } %>
            </div>
        <% } %>

        <!-- Product Cards -->
        <div class="product-cards">
            <div class="product-card card-1">
                <div class="card-label">JUST SELLING OUT NOW!</div>
                <div class="card-title">Velvet Matte</div>
                <div class="card-subtitle">2,345 Units Sold</div>
            </div>
            
            <div class="product-card card-2">
                <div class="card-label">LOW STOCK ALERT</div>
                <div class="card-title">8 Items</div>
                <div class="card-subtitle">Requires immediate restock</div>
            </div>
            
            <div class="product-card card-3">
                <div class="card-label">NEW ARRIVALS</div>
                <div class="card-title">Silk Collection</div>
                <div class="card-subtitle">Launching in 4 days</div>
            </div>
        </div>
    </main>

    <script>
        // Toggle product status
        async function toggleStatus(productId, currentStatus) {
            try {
                const response = await fetch(`/admin/products/toggle-status/${productId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Error updating product status');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error updating product status');
            }
        }

        // Delete product
        async function deleteProduct(productId) {
            if (!confirm('Are you sure you want to delete this product and all its variants?')) {
                return;
            }

            try {
                const response = await fetch(`/admin/products/delete/${productId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    // Remove the row from table
                    const row = document.getElementById('product-row-' + productId);
                    if (row) {
                        row.remove();
                    }
                    alert(data.message);
                    // Reload to update pagination
                    window.location.reload();
                } else {
                    alert(data.message || 'Error deleting product');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error deleting product');
            }
        }
    </script>
</body>
</html>
