<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Users - Veloura</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-red: #5c1e28;
            --main-bg: #f4f2f0;
            --sidebar-bg: #fcfbf9;
            --card-bg: #fbfbfb;
            --text-dark: #2d2a29;
            --text-gray: #888380;
            --text-light: #b3aea9;
            --border-color: #e5e2e0;
            
            --table-header-bg: #742533; /* Dark Maroon */
            --table-header-text: #ffffff;
            
            --btn-block-bg: #f8c8cc;
            --btn-block-text: #b53846;
            
            --btn-unblock-bg: #f4d99c;
            --btn-unblock-text: #5c4e28;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* --- Sidebar (Identical to Dashboard) --- */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .sidebar-header {
            padding: 30px 40px;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 600;
            color: var(--primary-red);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .sidebar-menu {
            overflow-y: auto;
            list-style: none;
            padding: 10px 0;
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 15px 40px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar-menu a i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            margin-right: 15px;
        }

        .sidebar-menu a:hover {
            background-color: #f7f1f1;
        }

        .sidebar-menu a.active {
            background-color: #f7eded;
            color: var(--primary-red);
            font-weight: 600;
        }

        .sidebar-menu a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background-color: var(--primary-red);
        }

        .sidebar-menu a.active i {
            color: var(--primary-red);
        }

        .sidebar-menu .logout-btn {
            display: block;
            width: 100%;
            padding: 14px !important;
            background-color: #c9302c;
            color: #ffffff !important;
            text-align: center;
            border-radius: 6px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.2s;
            margin: 0;
        }

        .sidebar-menu .logout-btn:hover {
            background-color: #ac2925;
            color: #ffffff !important;
        }

        .sidebar-menu .logout-btn i {
            display: none;
        }

        .logout-btn {
            display: block;
            width: 100%;
            padding: 14px !important;
            background-color: #c9302c;
            color: #ffffff !important;
            text-align: center;
            border-radius: 6px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.2s;
        }

        .logout-btn:hover {
            background-color: #ac2925;
            color: #ffffff !important;
        }

        /* --- Main Content --- */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            padding: 40px;
        }

        /* Top Controls Area */
        .page-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .filter-group {
            display: flex;
            align-items: center;
            background-color: #e9e6e4;
            border-radius: 4px;
            overflow: hidden;
        }
        
        .filter-icon {
            padding: 12px 15px;
            color: var(--text-dark);
            border-right: 1px solid var(--border-color);
        }

        .filter-label {
            padding: 12px 15px;
            font-size: 11px;
            font-weight: 700;
            color: var(--text-dark);
            text-transform: uppercase;
        }

        .filter-select {
            padding: 12px 15px;
            border: none;
            background: transparent;
            font-size: 12px;
            color: var(--text-dark);
            outline: none;
            cursor: pointer;
            border-left: 1px solid var(--border-color);
        }

        .search-box {
            position: relative;
            width: 350px;
            display: flex;
            gap: 10px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 20px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 13px;
            font-style: italic;
            outline: none;
            background-color: #ffffff;
            color: var(--text-gray);
        }

        .search-btn {
            padding: 12px 20px;
            background-color: var(--primary-red);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .search-btn:hover {
            background-color: #40131b;
        }

        .clear-btn {
            padding: 12px 15px;
            background-color: #6c757d;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .clear-btn:hover {
            background-color: #5a6268;
        }

        /* Table Section */
        .table-container {
            background-color: var(--card-bg);
            border-radius: 8px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            margin-bottom: 40px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            text-align: left;
            padding: 20px;
            font-family: 'Playfair Display', serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--table-header-text);
            text-transform: uppercase;
            letter-spacing: 1px;
            background-color: var(--table-header-bg);
        }

        .data-table td {
            padding: 20px;
            font-size: 13px;
            color: var(--text-dark);
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }
        
        .data-table tbody tr {
            background-color: #ffffff;
        }

        .data-table tbody tr:nth-child(even) {
            background-color: #faf9f8;
        }

        .data-table tr:last-child td {
            border-bottom: none;
        }

        .td-sno {
            color: var(--text-gray);
            width: 80px;
        }
        
        .td-name {
            font-weight: 600;
        }

        /* Action Buttons */
        .btn-action {
            padding: 8px 20px;
            border: none;
            border-radius: 2px;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: opacity 0.2s;
            width: 100px;
        }

        .btn-action:hover {
            opacity: 0.8;
        }

        .btn-block {
            background-color: var(--btn-block-bg);
            color: var(--btn-block-text);
            border: 1px solid #eba4ac;
        }

        .btn-unblock {
            background-color: var(--btn-unblock-bg);
            color: var(--btn-unblock-text);
            border: 1px solid #dcb56a;
        }

        /* Pagination */
        .pagination-area {
            display: flex;
            justify-content: center;
            margin-top: auto;
            margin-bottom: 20px;
        }

        .pagination-controls {
            display: flex;
            gap: 8px;
            background-color: white;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
        }

        .page-btn {
            min-width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-color);
            background-color: white;
            color: var(--text-dark);
            font-size: 12px;
            font-weight: 500;
            border-radius: 2px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            padding: 0 10px;
        }

        .page-btn:hover {
            background-color: #f0f0f0;
        }

        .page-btn.active {
            background-color: var(--table-header-bg);
            color: white;
            border-color: var(--table-header-bg);
        }

        .page-text {
            color: var(--text-gray);
            font-size: 12px;
        }

    </style>
<script src="/js/prevent-back.js"></script>
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/admin/dashboard" class="logo">Veloura</a>
        </div>
        
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard"><i class="fas fa-th-large"></i> Dashboard</a></li>
            <li><a href="#"><i class="fas fa-box"></i> Products</a></li>
            <li><a href="#"><i class="fas fa-clipboard-list"></i> Order List</a></li>
            <li><a href="/admin/users" class="active"><i class="fas fa-users"></i> Users</a></li>
            <li><a href="#"><i class="fas fa-chart-line"></i> Sales Report</a></li>
            <li><a href="#"><i class="fas fa-ticket-alt"></i> Coupons</a></li>
            <li><a href="#"><i class="fas fa-list"></i> Category</a></li>
            <li><a href="#"><i class="fas fa-star"></i> Reviews</a></li>
            <li style="padding: 20px 40px; margin-top: 10px;">
                <a href="/admin/logout" class="logout-btn">Log Out</a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        
        <!-- Top Controls -->
        <div class="page-top">
            <div class="filter-group">
                <div class="filter-icon"><i class="fas fa-filter"></i></div>
                <div class="filter-label">FILTER BY</div>
                <select name="status" class="filter-select" onchange="filterUsers()">
                    <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Users</option>
                    <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="blocked" <%= currentStatus === 'blocked' ? 'selected' : '' %>>Blocked</option>
                </select>
            </div>
            
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search by name or email..." value="<%= searchQuery %>">
                <button type="button" class="search-btn" onclick="performSearch()">
                    <i class="fas fa-search"></i> Search
                </button>
                <% if (searchQuery) { %>
                <button type="button" class="clear-btn" onclick="clearSearch()">
                    <i class="fas fa-times"></i>
                </button>
                <% } %>
            </div>
            
        </div>

        <!-- Users Table -->
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>S.NO</th>
                        <th>NAME</th>
                        <th>EMAIL</th>
                        <th>MOBILE</th>
                        <th>UPDATE</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users && users.length > 0) { %>
                        <% users.forEach((user, index) => { %>
                            <tr>
                                <td class="td-sno"><%= (currentPage - 1) * 5 + (index + 1) %></td>
                                <td class="td-name"><%= user.name %></td>
                                <td><%= user.email %></td>
                                <td><%= user.phone || 'N/A' %></td>
                                <td>
                                    <button 
                                        class="btn-action <%= user.isBlocked ? 'btn-unblock' : 'btn-block' %>" 
                                        onclick="toggleUserStatus('<%= user._id %>', this)">
                                        <%= user.isBlocked ? 'UNBLOCK' : 'BLOCK' %>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 30px;">No users found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div class="pagination-area">
            <div class="pagination-controls">
                
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>&search=<%= searchQuery %>&status=<%= currentStatus %>" class="page-btn">
                        <span class="page-text"><i class="fas fa-chevron-left" style="font-size: 10px; margin-right: 5px;"></i> Back</span>
                    </a>
                <% } %>

                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %>&search=<%= searchQuery %>&status=<%= currentStatus %>" 
                       class="page-btn <%= currentPage === i ? 'active' : '' %>">
                       <%= i %>
                    </a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>&search=<%= searchQuery %>&status=<%= currentStatus %>" class="page-btn">
                        <span class="page-text">Next <i class="fas fa-chevron-right" style="font-size: 10px; margin-left: 5px;"></i></span>
                    </a>
                <% } %>
                
            </div>
        </div>
        <% } %>

    </main>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const currentStatus = '<%= currentStatus %>';
const currentSearch = '<%= searchQuery %>';


function performSearch() {
    const searchValue = document.getElementById('searchInput').value.trim();
    const statusValue = document.querySelector('.filter-select').value;
   
    const params = new URLSearchParams();
    if (searchValue) params.append('search', searchValue);
    if (statusValue !== 'all') params.append('status', statusValue);
    params.append('page', '1'); 
    
    window.location.href = `/admin/users?${params.toString()}`;
}


function filterUsers() {
    const searchValue = document.getElementById('searchInput').value.trim();
    const statusValue = document.querySelector('.filter-select').value;
    
    const params = new URLSearchParams();
    if (searchValue) params.append('search', searchValue);
    if (statusValue !== 'all') params.append('status', statusValue);
    params.append('page', '1');
    
    window.location.href = `/admin/users?${params.toString()}`;
}


function clearSearch() {
    document.getElementById('searchInput').value = '';
    const statusValue = document.querySelector('.filter-select').value;
    
    const params = new URLSearchParams();
    if (statusValue !== 'all') params.append('status', statusValue);
    params.append('page', '1');
    
    window.location.href = `/admin/users?${params.toString()}`;
}

document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    
  
    searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            performSearch();
        }
    });
});


async function toggleUserStatus(userId, buttonElement) {
    const isCurrentlyBlocked = buttonElement.innerText.trim() === 'UNBLOCK';
    const actionText = isCurrentlyBlocked ? 'unblock' : 'block';
    
    const result = await Swal.fire({
        title: `Are you sure?`,
        text: `Do you want to ${actionText} this user?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: isCurrentlyBlocked ? '#dcb56a' : '#eba4ac',
        cancelButtonColor: '#2d2a29',
        confirmButtonText: `Yes, ${actionText}!`
    });

    if (result.isConfirmed) {
        try {
            const response = await fetch(`/admin/users/${userId}/toggle-block`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const data = await response.json();
            
            if (data.success) {
                if (data.isBlocked) {
                    buttonElement.className = 'btn-action btn-unblock';
                    buttonElement.innerText = 'UNBLOCK';
                } else {
                    buttonElement.className = 'btn-action btn-block';
                    buttonElement.innerText = 'BLOCK';
                }
                Swal.fire('Success!', data.message, 'success');
            } else {
                Swal.fire('Error!', data.message || 'Something went wrong.', 'error');
            }
        } catch (error) {
            console.error('Error:', error);
            Swal.fire('Error!', 'Failed to connect to the server.', 'error');
        }
    }
}
</script>
</body>
</html>
