<aside class="sidebar">
    <div class="profile-section">
        <div class="profile-avatar" style="overflow: hidden;">
            <% if (typeof user !== 'undefined' && user.profileImage) { %>
                <img src="<%= user.profileImage %>" alt="Profile Picture" style="width: 100%; height: 100%; object-fit: cover;">
            <% } else { %>
                <i class="fas fa-user"></i>
            <% } %>
        </div>
        <div class="profile-name"><%= typeof user !== 'undefined' ? user.name : 'User' %></div>
    </div>

    <ul class="sidebar-menu">
        <li><a href="/profile" class="<%= typeof activeTab !== 'undefined' && activeTab === 'profile' ? 'active' : '' %>"><i class="far fa-user-circle"></i> Account Overview</a></li>
        <li><a href="/profile/orders" class="<%= typeof activeTab !== 'undefined' && activeTab === 'orders' ? 'active' : '' %>"><i class="fas fa-box"></i> My Orders</a></li>
        <li><a href="/profile/addresses" class="<%= typeof activeTab !== 'undefined' && activeTab === 'addresses' ? 'active' : '' %>"><i class="fas fa-map-marker-alt"></i> Manage Addresses</a></li>
        <li><a href="/profile/wallet" class="<%= typeof activeTab !== 'undefined' && activeTab === 'wallet' ? 'active' : '' %>"><i class="fas fa-wallet"></i> Wallet</a></li>
        <li><a href="/profile/password" class="<%= typeof activeTab !== 'undefined' && activeTab === 'password' ? 'active' : '' %>"><i class="fas fa-lock"></i> Password</a></li>
        <li><a href="/wishlist" class="<%= typeof activeTab !== 'undefined' && activeTab === 'wishlist' ? 'active' : '' %>"><i class="far fa-heart"></i> Wishlist</a></li>
    </ul>

    <button class="logout-btn" onclick="handleSidebarLogout(event)">Log Out</button>
</aside>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function handleSidebarLogout(event) {
        if (event) event.preventDefault();
        
        // Use Swal if available, fallback to default confirm if not
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: 'Logging Out?',
                text: 'Are you sure you want to log out of Veloura?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#5c1e28',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Yes, Log Out',
                cancelButtonText: 'Cancel',
                borderRadius: '12px'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/logout';
                }
            });
        } else {
            if (confirm('Are you sure you want to log out of Veloura?')) {
                window.location.href = '/logout';
            }
        }
    }
</script>